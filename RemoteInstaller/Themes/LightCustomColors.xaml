<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- 浅色主题配色方案 -->
    <!-- 根据 UI_SPEC.md 定义的浅色主题规范 -->
    
    <!-- 主色板 -->
    <Color x:Key="PrimaryColor">#4F46E5</Color>
    <Color x:Key="PrimaryDarkColor">#4338CA</Color>
    <Color x:Key="PrimaryLightColor">#6366F1</Color>
    <Color x:Key="SecondaryColor">#0891B2</Color>
    
    <!-- 背景色 -->
    <Color x:Key="BackgroundColor">#F9FAFB</Color>
    <Color x:Key="SurfaceColor">#FFFFFF</Color>
    <Color x:Key="SurfaceLightColor">#F3F4F6</Color>
    <Color x:Key="SurfaceDarkColor">#E5E7EB</Color>
    
    <!-- 状态颜色 -->
    <Color x:Key="ErrorColor">#DC2626</Color>
    <Color x:Key="SuccessColor">#059669</Color>
    <Color x:Key="WarningColor">#D97706</Color>
    <Color x:Key="InfoColor">#2563EB</Color>
    
    <!-- 文本颜色 -->
    <Color x:Key="TextPrimaryColor">#111827</Color>
    <Color x:Key="TextSecondaryColor">#6B7280</Color>
    <Color x:Key="TextDisabledColor">#9CA3AF</Color>
    
    <!-- 边框颜色 -->
    <Color x:Key="BorderColor">#E5E7EB</Color>
    <Color x:Key="BorderLightColor">#F3F4F6</Color>
    
    <!-- 自定义颜色 (与深色主题保持一致的品牌色) -->
    <Color x:Key="CustomPrimary">#4F46E5</Color>
    <Color x:Key="CustomSecondary">#0891B2</Color>
    <Color x:Key="CustomSuccess">#059669</Color>
    <Color x:Key="CustomError">#DC2626</Color>
    <Color x:Key="CustomWarning">#D97706</Color>
    <Color x:Key="CustomInfo">#2563EB</Color>
    
    <!-- 浅色主题背景 -->
    <Color x:Key="LightBackground">#F9FAFB</Color>
    <Color x:Key="LightSurface">#FFFFFF</Color>
    <Color x:Key="LightSurfaceLight">#F3F4F6</Color>
    <Color x:Key="LightSurfaceDark">#E5E7EB</Color>
    
    <!-- SolidColorBrush 资源 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}"/>
    
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLightColor}"/>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDarkColor}"/>
    
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextDisabledBrush" Color="{StaticResource TextDisabledColor}"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderLightBrush" Color="{StaticResource BorderLightColor}"/>
    
    <!-- 自定义画笔 -->
    <SolidColorBrush x:Key="CustomPrimaryBrush" Color="{StaticResource CustomPrimary}"/>
    <SolidColorBrush x:Key="CustomSecondaryBrush" Color="{StaticResource CustomSecondary}"/>
    <SolidColorBrush x:Key="CustomSuccessBrush" Color="{StaticResource CustomSuccess}"/>
    <SolidColorBrush x:Key="CustomErrorBrush" Color="{StaticResource CustomError}"/>
    <SolidColorBrush x:Key="CustomWarningBrush" Color="{StaticResource CustomWarning}"/>
    <SolidColorBrush x:Key="CustomInfoBrush" Color="{StaticResource CustomInfo}"/>
    
    <!-- 浅色主题背景画笔 -->
    <SolidColorBrush x:Key="LightBackgroundBrush" Color="{StaticResource LightBackground}"/>
    <SolidColorBrush x:Key="LightSurfaceBrush" Color="{StaticResource LightSurface}"/>
    <SolidColorBrush x:Key="LightSurfaceLightBrush" Color="{StaticResource LightSurfaceLight}"/>
    <SolidColorBrush x:Key="LightSurfaceDarkBrush" Color="{StaticResource LightSurfaceDark}"/>
    
    <!-- MaterialDesignInXaml 主题覆盖 -->
    <SolidColorBrush x:Key="MaterialDesignDarkPrimary" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="MaterialDesignLightPrimary" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="MaterialDesignDarkPrimaryLight" Color="{StaticResource PrimaryLightColor}"/>
    <SolidColorBrush x:Key="MaterialDesignLightPrimaryDark" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="MaterialDesignDarkSecondary" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="MaterialDesignLightSecondary" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="MaterialDesignDarkSecondaryLight" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="MaterialDesignLightSecondaryDark" Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="MaterialDesignDarkBackground" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="MaterialDesignLightBackground" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="MaterialDesignDarkForeground" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="MaterialDesignLightForeground" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="MaterialDesignDarkMid" Color="{StaticResource SurfaceLightColor}"/>
    <SolidColorBrush x:Key="MaterialDesignLightMid" Color="{StaticResource SurfaceLightColor}"/>
    <SolidColorBrush x:Key="MaterialDesignDarkLight" Color="{StaticResource SurfaceLightColor}"/>
    <SolidColorBrush x:Key="MaterialDesignLightDark" Color="{StaticResource SurfaceDarkColor}"/>
    <SolidColorBrush x:Key="MaterialDesignDarkShadow" Color="#1E000000"/>
    <SolidColorBrush x:Key="MaterialDesignLightShadow" Color="#1E000000"/>
    
    <!-- 日志颜色 (浅色主题) -->
    <SolidColorBrush x:Key="LogInfoBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="LogSuccessBrush" Color="#059669"/>
    <SolidColorBrush x:Key="LogWarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="LogErrorBrush" Color="#DC2626"/>
    
    <!-- MaterialDesign 50 色调 (浅色主题) -->
    <SolidColorBrush x:Key="MaterialDesign50" Color="{StaticResource SurfaceLightColor}"/>
    <SolidColorBrush x:Key="MaterialDesign100" Color="{StaticResource BorderLightColor}"/>
    <SolidColorBrush x:Key="MaterialDesign200" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="MaterialDesign300" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="MaterialDesign400" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="MaterialDesign500" Color="#6B7280"/>
    <SolidColorBrush x:Key="MaterialDesign600" Color="#4B5563"/>
    <SolidColorBrush x:Key="MaterialDesign700" Color="#374151"/>
    <SolidColorBrush x:Key="MaterialDesign800" Color="#1F2937"/>
    <SolidColorBrush x:Key="MaterialDesign900" Color="#111827"/>
    
    <!-- 文本资源 (浅色主题) - SolidColorBrush -->
    <SolidColorBrush x:Key="MaterialDesignBody" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="MaterialDesignBodyLight" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="MaterialDesignBodyDisabled" Color="{StaticResource TextDisabledColor}"/>
    <SolidColorBrush x:Key="MaterialDesignDivider" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="MaterialDesignPaper" Color="{StaticResource SurfaceColor}"/>
    
    <!-- 修复：添加应用卡片相关的资源定义，与 DarkTheme.xaml 保持一致 -->
    <!-- 应用图标背景颜色 -->
    <Color x:Key="AppIconBackgroundColor">#6366F1</Color>
    <SolidColorBrush x:Key="AppIconBackgroundBrush" Color="{StaticResource AppIconBackgroundColor}"/>
    
    <!-- 操作系统标签颜色和画笔 -->
    <Color x:Key="AppOsTagBackgroundColor">#EEF2FF</Color>
    <Color x:Key="AppOsTagTextColor">#6366F1</Color>
    <SolidColorBrush x:Key="AppOsTagBackgroundBrush" Color="{StaticResource AppOsTagBackgroundColor}"/>
    <SolidColorBrush x:Key="AppOsTagTextBrush" Color="{StaticResource AppOsTagTextColor}"/>
    
    <!-- 运行中标签颜色和画笔 -->
    <Color x:Key="AppRunningTagBackgroundColor">#D1FAE5</Color>
    <Color x:Key="AppRunningTagTextColor">#10B981</Color>
    <SolidColorBrush x:Key="AppRunningTagBackgroundBrush" Color="{StaticResource AppRunningTagBackgroundColor}"/>
    <SolidColorBrush x:Key="AppRunningTagTextBrush" Color="{StaticResource AppRunningTagTextColor}"/>
    
    <!-- 已安装标签颜色和画笔 -->
    <Color x:Key="AppInstalledTagBackgroundColor">#FEF3C7</Color>
    <Color x:Key="AppInstalledTagTextColor">#F59E0B</Color>
    <SolidColorBrush x:Key="AppInstalledTagBackgroundBrush" Color="{StaticResource AppInstalledTagBackgroundColor}"/>
    <SolidColorBrush x:Key="AppInstalledTagTextBrush" Color="{StaticResource AppInstalledTagTextColor}"/>
    
    <!-- ==================== 滚动条颜色定义 (浅色主题) ==================== -->
    <!-- 配色方案根据 Material Design 浅色主题规范设计 -->
    <!-- 确保滚动条在白色/浅色背景下清晰可见 -->
    
    <!-- 滚动条轨道颜色 - 浅灰色背景 -->
    <Color x:Key="ScrollBarTrackColor">#E8E8E8</Color>
    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="{StaticResource ScrollBarTrackColor}"/>
    
    <!-- 滚动条滑块颜色 - 中灰色，正常状态 -->
    <Color x:Key="ScrollBarThumbColor">#BDBDBD</Color>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    
    <!-- 滚动条悬停颜色 - 深灰色，鼠标悬停时 -->
    <Color x:Key="ScrollBarThumbHoverColor">#9E9E9E</Color>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="{StaticResource ScrollBarThumbHoverColor}"/>
    
    <!-- 滚动条按下颜色 - 更深的灰色，鼠标按下时 -->
    <Color x:Key="ScrollBarThumbPressedColor">#757575</Color>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="{StaticResource ScrollBarThumbPressedColor}"/>
    
    <!-- 滚动条箭头按钮颜色 -->
    <Color x:Key="ScrollBarButtonColor">#BDBDBD</Color>
    <SolidColorBrush x:Key="ScrollBarButtonBrush" Color="{StaticResource ScrollBarButtonColor}"/>
    
    <!-- 滚动条箭头悬停颜色 -->
    <Color x:Key="ScrollBarButtonHoverColor">#9E9E9E</Color>
    <SolidColorBrush x:Key="ScrollBarButtonHoverBrush" Color="{StaticResource ScrollBarButtonHoverColor}"/>
    
    <!-- 滚动条箭头按下颜色 -->
    <Color x:Key="ScrollBarButtonPressedColor">#757575</Color>
    <SolidColorBrush x:Key="ScrollBarButtonPressedBrush" Color="{StaticResource ScrollBarButtonPressedColor}"/>
    
    <!-- 滚动条禁用滑块颜色 - 非常浅的灰色，禁用状态 -->
    <Color x:Key="ScrollBarThumbDisabledColor">#E0E0E0</Color>
    <SolidColorBrush x:Key="ScrollBarThumbDisabledBrush" Color="{StaticResource ScrollBarThumbDisabledColor}"/>
    
    <!-- 滚动条样式 -->
    <Style x:Key="ScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
        <Setter Property="Foreground" Value="{StaticResource ScrollBarThumbBrush}"/>
        <Setter Property="Background" Value="{StaticResource ScrollBarTrackBrush}"/>
        <Setter Property="Width" Value="12"/>
        <Setter Property="MinWidth" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid x:Name="GridRoot" Background="{StaticResource ScrollBarTrackBrush}">
                        <!-- 垂直滚动条模板 -->
                        <Grid x:Name="VerticalGrid">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- 顶部箭头按钮 -->
                            <RepeatButton x:Name="ButtonUp"
                                          Command="ScrollBar.LineUpCommand"
                                          CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                          Grid.Row="0"
                                          Focusable="false">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border x:Name="ButtonBorder" Background="Transparent" Height="12">
                                            <Path x:Name="ArrowPath"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="M 0,4 L 4,0 L 8,4 L 4,8 Z"
                                                  Fill="{TemplateBinding Foreground}"
                                                  Stretch="Uniform"
                                                  Height="6" Width="6"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="ArrowPath" Property="Fill" Value="{StaticResource ScrollBarButtonHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter TargetName="ArrowPath" Property="Fill" Value="{StaticResource ScrollBarButtonPressedBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                            
                            <!-- 滚动条轨道和滑块 -->
                            <Track x:Name="PART_Track"
                                   Grid.Row="1"
                                   IsDirectionReversed="true">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                                  CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="ThumbVertical"
                                           Focusable="false"
                                           Background="{TemplateBinding Foreground}"
                                           Width="8">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Width="8"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollBarThumbHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollBarThumbPressedBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                                  CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                            
                            <!-- 底部箭头按钮 -->
                            <RepeatButton x:Name="ButtonDown"
                                          Command="ScrollBar.LineDownCommand"
                                          CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                          Grid.Row="2"
                                          Focusable="false">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border x:Name="ButtonBorder" Background="Transparent" Height="12">
                                            <Path x:Name="ArrowPath"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="M 0,0 L 4,4 L 8,0 L 4,8 Z"
                                                  Fill="{TemplateBinding Foreground}"
                                                  Stretch="Uniform"
                                                  Height="6" Width="6"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="true">
                                                <Setter TargetName="ArrowPath" Property="Fill" Value="{StaticResource ScrollBarButtonHoverBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="true">
                                                <Setter TargetName="ArrowPath" Property="Fill" Value="{StaticResource ScrollBarButtonPressedBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                        </Grid>
                        
                        <!-- 水平滚动条模板 -->
                        <Grid x:Name="HorizontalGrid" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <!-- 左侧箭头按钮 -->
                            <RepeatButton x:Name="ButtonLeft"
                                          Command="ScrollBar.LineLeftCommand"
                                          CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                          Grid.Column="0"
                                          Focusable="false">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border Background="Transparent" Width="12">
                                            <Path HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="M 4,0 L 0,4 L 4,8 L 8,4 Z"
                                                  Fill="{TemplateBinding Foreground}"
                                                  Stretch="Uniform"
                                                  Height="6" Width="6"/>
                                        </Border>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                            
                            <!-- 滚动条轨道和滑块 -->
                            <Track x:Name="PART_HorizontalTrack"
                                   Grid.Column="1"
                                   IsDirectionReversed="false">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                                  CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="false"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="ThumbHorizontal"
                                           Focusable="false"
                                           Background="{TemplateBinding Foreground}"
                                           Height="8">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border x:Name="ThumbBorder"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Height="8"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollBarThumbHoverBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="true">
                                                        <Setter TargetName="ThumbBorder" Property="Background" Value="{StaticResource ScrollBarThumbPressedBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                                  CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="false"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                            
                            <!-- 右侧箭头按钮 -->
                            <RepeatButton x:Name="ButtonRight"
                                          Command="ScrollBar.LineRightCommand"
                                          CommandParameter="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                          Grid.Column="2"
                                          Focusable="false">
                                <RepeatButton.Template>
                                    <ControlTemplate TargetType="RepeatButton">
                                        <Border Background="Transparent" Width="12">
                                            <Path HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Data="M 0,0 L 8,4 L 0,8 Z"
                                                  Fill="{TemplateBinding Foreground}"
                                                  Stretch="Uniform"
                                                  Height="6" Width="6"/>
                                        </Border>
                                    </ControlTemplate>
                                </RepeatButton.Template>
                            </RepeatButton>
                        </Grid>
                    </Grid>
                    
                    <!-- 根据滚动条方向切换模板 -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="VerticalGrid" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="HorizontalGrid" Property="Visibility" Value="Visible"/>
                            <Setter Property="Height" Value="12"/>
                            <Setter Property="MinHeight" Value="12"/>
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="MinWidth" Value="0"/>
                        </Trigger>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="VerticalGrid" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="HorizontalGrid" Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Width" Value="12"/>
                            <Setter Property="MinWidth" Value="12"/>
                            <Setter Property="Height" Value="Auto"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Trigger>
                        <!-- 禁用状态 -->
                        <Trigger Property="IsEnabled" Value="false">
                            <Setter Property="Foreground" Value="{StaticResource ScrollBarThumbDisabledBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <!-- ScrollViewer 样式 - 使用自定义滚动条 -->
    <Style x:Key="ScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <ScrollContentPresenter Grid.Column="0"
                                                Grid.Row="0"
                                                Margin="{TemplateBinding Padding}"/>
                        
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1"
                                   Grid.Row="0"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Style="{StaticResource ScrollBarStyle}"/>
                        
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="0"
                                   Grid.Row="1"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                                   Style="{StaticResource ScrollBarStyle}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
</ResourceDictionary>
