<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== 主色调 - 鲜明版 ==================== -->
    <Color x:Key="CustomPrimary">#0EA5E9</Color>
    <Color x:Key="CustomPrimaryHover">#38BDF8</Color>
    <Color x:Key="CustomPrimaryPressed">#0369A1</Color>
    <Color x:Key="CustomSecondary">#14B8A6</Color>
    <Color x:Key="CustomSuccess">#22C55E</Color>
    <Color x:Key="CustomSuccessHover">#4ADE80</Color>
    <Color x:Key="CustomError">#EF4444</Color>
    <Color x:Key="CustomErrorHover">#F87171</Color>
    <Color x:Key="CustomWarning">#D97706</Color>
    <Color x:Key="CustomWarningHover">#FBBF24</Color>
    <Color x:Key="CustomInfo">#60A5FA</Color>
    <Color x:Key="CustomPink">#FB7185</Color>
    <Color x:Key="CustomOrange">#F97316</Color>
    <Color x:Key="CustomCyan">#22D3EE</Color>

    <SolidColorBrush x:Key="CustomPrimaryBrush" Color="{StaticResource CustomPrimary}"/>
    <SolidColorBrush x:Key="CustomPrimaryHoverBrush" Color="{StaticResource CustomPrimaryHover}"/>
    <SolidColorBrush x:Key="CustomPrimaryPressedBrush" Color="{StaticResource CustomPrimaryPressed}"/>
    <SolidColorBrush x:Key="CustomSecondaryBrush" Color="{StaticResource CustomSecondary}"/>
    <SolidColorBrush x:Key="CustomSuccessBrush" Color="{StaticResource CustomSuccess}"/>
    <SolidColorBrush x:Key="CustomSuccessHoverBrush" Color="{StaticResource CustomSuccessHover}"/>
    <SolidColorBrush x:Key="CustomErrorBrush" Color="{StaticResource CustomError}"/>
    <SolidColorBrush x:Key="CustomErrorHoverBrush" Color="{StaticResource CustomErrorHover}"/>
    <SolidColorBrush x:Key="CustomWarningBrush" Color="{StaticResource CustomWarning}"/>
    <SolidColorBrush x:Key="CustomWarningHoverBrush" Color="{StaticResource CustomWarningHover}"/>
    <SolidColorBrush x:Key="CustomInfoBrush" Color="{StaticResource CustomInfo}"/>
    <SolidColorBrush x:Key="CustomPinkBrush" Color="{StaticResource CustomPink}"/>
    <SolidColorBrush x:Key="CustomOrangeBrush" Color="{StaticResource CustomOrange}"/>
    <SolidColorBrush x:Key="CustomCyanBrush" Color="{StaticResource CustomCyan}"/>

    <!-- ==================== 深色主题 ==================== -->
    <Color x:Key="DarkBackground">#07111F</Color>
    <Color x:Key="DarkSurface">#0F1B2D</Color>
    <Color x:Key="DarkSurfaceLight">#16253A</Color>
    <Color x:Key="DarkSurfaceElevated">#20314C</Color>
    <Color x:Key="DarkBorder">#2B3F5F</Color>
    <Color x:Key="DarkBorderLight">#466283</Color>

    <SolidColorBrush x:Key="DarkBackgroundBrush" Color="{StaticResource DarkBackground}"/>
    <SolidColorBrush x:Key="DarkSurfaceBrush" Color="{StaticResource DarkSurface}"/>
    <SolidColorBrush x:Key="DarkSurfaceLightBrush" Color="{StaticResource DarkSurfaceLight}"/>
    <SolidColorBrush x:Key="DarkSurfaceElevatedBrush" Color="{StaticResource DarkSurfaceElevated}"/>
    <SolidColorBrush x:Key="DarkBorderBrush" Color="{StaticResource DarkBorder}"/>
    <SolidColorBrush x:Key="DarkBorderLightBrush" Color="{StaticResource DarkBorderLight}"/>

    <!-- 深色主题文字 -->
    <Color x:Key="DarkTextPrimary">#F8FAFC</Color>
    <Color x:Key="DarkTextSecondary">#B6C2D1</Color>
    <Color x:Key="DarkTextDisabled">#7C8CA0</Color>

    <SolidColorBrush x:Key="DarkTextPrimaryBrush" Color="{StaticResource DarkTextPrimary}"/>
    <SolidColorBrush x:Key="DarkTextSecondaryBrush" Color="{StaticResource DarkTextSecondary}"/>
    <SolidColorBrush x:Key="DarkTextDisabledBrush" Color="{StaticResource DarkTextDisabled}"/>

    <!-- ==================== 浅色主题 ==================== -->
    <Color x:Key="LightBackground">#F4F7FB</Color>
    <Color x:Key="LightSurface">#FFFFFF</Color>
    <Color x:Key="LightSurfaceLight">#F8FBFF</Color>
    <Color x:Key="LightSurfaceElevated">#EDF4FB</Color>
    <Color x:Key="LightBorder">#D8E3F0</Color>
    <Color x:Key="LightBorderDark">#B8C8DA</Color>

    <SolidColorBrush x:Key="LightBackgroundBrush" Color="{StaticResource LightBackground}"/>
    <SolidColorBrush x:Key="LightSurfaceBrush" Color="{StaticResource LightSurface}"/>
    <SolidColorBrush x:Key="LightSurfaceLightBrush" Color="{StaticResource LightSurfaceLight}"/>
    <SolidColorBrush x:Key="LightSurfaceElevatedBrush" Color="{StaticResource LightSurfaceElevated}"/>
    <SolidColorBrush x:Key="LightBorderBrush" Color="{StaticResource LightBorder}"/>
    <SolidColorBrush x:Key="LightBorderDarkBrush" Color="{StaticResource LightBorderDark}"/>

    <!-- 浅色主题文字 -->
    <Color x:Key="LightTextPrimary">#0F172A</Color>
    <Color x:Key="LightTextSecondary">#475569</Color>
    <Color x:Key="LightTextDisabled">#94A3B8</Color>

    <SolidColorBrush x:Key="LightTextPrimaryBrush" Color="{StaticResource LightTextPrimary}"/>
    <SolidColorBrush x:Key="LightTextSecondaryBrush" Color="{StaticResource LightTextSecondary}"/>
    <SolidColorBrush x:Key="LightTextDisabledBrush" Color="{StaticResource LightTextDisabled}"/>

    <!-- ==================== 渐变和特效 - 鲜明版 ==================== -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0EA5E9" Offset="0"/>
        <GradientStop Color="#14B8A6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#16A34A" Offset="0"/>
        <GradientStop Color="#4ADE80" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WarningGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#D97706" Offset="0"/>
        <GradientStop Color="#FBBF24" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="ErrorGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#DC2626" Offset="0"/>
        <GradientStop Color="#F87171" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="InfoGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2563EB" Offset="0"/>
        <GradientStop Color="#60A5FA" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CyanGradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0891B2" Offset="0"/>
        <GradientStop Color="#22D3EE" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="SunsetGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#1D4ED8" Offset="0"/>
        <GradientStop Color="#0EA5E9" Offset="0.55"/>
        <GradientStop Color="#14B8A6" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="OceanGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0F766E" Offset="0"/>
        <GradientStop Color="#38BDF8" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardHoverGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#16253A" Offset="0"/>
        <GradientStop Color="#20314C" Offset="1"/>
    </LinearGradientBrush>

    <!-- 阴影效果 - 性能优化版：降低模糊半径和不透明度，减少 WPF 逐像素渲染成本 -->
    <DropShadowEffect x:Key="CardShadow" Color="#020617" Opacity="0.14" BlurRadius="12" ShadowDepth="3"/>
    <DropShadowEffect x:Key="CardHoverShadow" Color="#0EA5E9" Opacity="0.18" BlurRadius="28" ShadowDepth="10"/>
    <DropShadowEffect x:Key="PrimaryButtonShadow" Color="#0369A1" Opacity="0.32" BlurRadius="18" ShadowDepth="4"/>
    <DropShadowEffect x:Key="GlowEffect" Color="#22D3EE" Opacity="0.3" BlurRadius="28" ShadowDepth="0"/>

    <!-- 圆角 -->
    <CornerRadius x:Key="CornerRadiusSmall">6</CornerRadius>
    <CornerRadius x:Key="CornerRadiusMedium">12</CornerRadius>
    <CornerRadius x:Key="CornerRadiusLarge">18</CornerRadius>
    <CornerRadius x:Key="CornerRadiusXLarge">24</CornerRadius>

    <!-- 间距 -->
    <Thickness x:Key="SpacingXS">4</Thickness>
    <Thickness x:Key="SpacingSM">8</Thickness>
    <Thickness x:Key="SpacingMD">12</Thickness>
    <Thickness x:Key="SpacingLG">18</Thickness>
    <Thickness x:Key="SpacingXL">24</Thickness>

</ResourceDictionary>
