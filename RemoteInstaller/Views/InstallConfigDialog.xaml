<Window x:Class="RemoteInstaller.Views.InstallConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}"
        Width="1000" Height="750"
        MinWidth="900" MinHeight="650"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="{DynamicResource MaterialDesignPaper}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题信息 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="{Binding ApplicationName}" 
                       FontSize="20" 
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryForegroundColor}"/>
            <TextBlock Text="{Binding ApplicationVersion}" 
                       FontSize="12" 
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,2,0,0"/>
            <TextBlock Text="{Binding TargetHost}" 
                       FontSize="11" 
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- 版本选择区域 -->
        <Border Grid.Row="1" Margin="0,0,0,15" Padding="15"
                Background="{DynamicResource MaterialDesign50}"
                CornerRadius="4"
                BorderBrush="{DynamicResource PrimaryHueLightBrush}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="版本选择" 
                           FontWeight="SemiBold"
                           VerticalAlignment="center"
                           Margin="0,0,0,10"/>
                
                <!-- 在线安装时显示版本选择 ComboBox -->
                <StackPanel Visibility="{Binding PackageSource, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=online}">
                    <ComboBox ItemsSource="{Binding AvailableVersions}"
                              SelectedItem="{Binding SelectedVersion}"
                              Style="{StaticResource DarkComboBoxStyle}"
                              materialDesign:HintAssist.Hint="请选择安装版本"
                              materialDesign:HintAssist.Foreground="{DynamicResource SecondaryTextBrush}"
                              materialDesign:HintAssist.HintOpacity="0.9"
                              IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"/>
                </StackPanel>

                <!-- 本地包时显示版本信息（只读） -->
                <StackPanel Visibility="{Binding IsLocalPackage, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Text="安装包版本：" 
                                   VerticalAlignment="center"
                                   Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" 
                                   Text="{Binding LocalPackageVersion}" 
                                   VerticalAlignment="center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 本地安装包设置 -->
        <Border Grid.Row="2" Margin="0,0,0,15" Padding="15"
                Background="{DynamicResource MaterialDesign50}"
                CornerRadius="4"
                BorderBrush="{DynamicResource PrimaryHueLightBrush}"
                BorderThickness="1">
            <StackPanel>
                <!-- 安装源选择 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="安装资源来源："
                               FontWeight="SemiBold"
                               VerticalAlignment="center"
                               Margin="0,0,10,0"/>
                    <RadioButton Content="本地资源"
                                 GroupName="PackageSource"
                                 IsChecked="{Binding PackageSource, Converter={StaticResource StringToBoolConverter}, ConverterParameter=local}"
                                 Margin="0,0,10,0"/>
                    <RadioButton Content="在线安装"
                                 GroupName="PackageSource"
                                 IsChecked="{Binding PackageSource, Converter={StaticResource StringToBoolConverter}, ConverterParameter=online}"/>
                </StackPanel>

                <!-- 本地包路径选择 -->
                <Grid Visibility="{Binding PackageSource, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=local}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding LocalPackagePath, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource DarkTextBoxStyle}"
                             Foreground="{DynamicResource PrimaryTextBrush}"
                             materialDesign:HintAssist.Hint="从 Scripts 对应目录自动检测本地资源"
                             materialDesign:HintAssist.Foreground="{DynamicResource SecondaryTextBrush}"
                             materialDesign:HintAssist.HintOpacity="0.9"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="False"/>

                    <Button Grid.Column="1"
                            Content="刷新检测"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding BrowsePackagePathCommand}"
                            Margin="5,0,0,0"/>
                </Grid>

                <!-- 提示信息 -->
                <TextBlock Text="推荐优先使用本地资源安装，请将安装包放入 Scripts 对应应用目录后再刷新检测"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
                <TextBlock Text="{Binding LocalResourceHint}"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Margin="0,4,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 安装摘要 -->
        <Border Grid.Row="3" Margin="0,0,0,15" Padding="15"
                Background="{DynamicResource MaterialDesign50}"
                CornerRadius="4"
                BorderBrush="{DynamicResource PrimaryHueLightBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="目标主机：" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TargetHost}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,16,0"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="安装来源：" FontWeight="SemiBold" Margin="0,0,8,0"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="本地资源"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Visibility="{Binding PackageSource, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=local}"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="在线安装"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Visibility="{Binding PackageSource, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=online}"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="安装版本：" FontWeight="SemiBold" Margin="0,10,8,0"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedVersion}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,10,16,0"
                           Visibility="{Binding PackageSource, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=online}"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LocalPackageVersion}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,10,16,0"
                           Visibility="{Binding PackageSource, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=local}"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="本地包路径：" FontWeight="SemiBold" Margin="0,10,8,0"
                           Visibility="{Binding PackageSource, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=local}"/>
                <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding LocalPackagePath}" Margin="0,10,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap"
                           Visibility="{Binding PackageSource, Converter={StaticResource StringToVisibilityConverter}, ConverterParameter=local}"/>
            </Grid>
        </Border>

        <!-- 安装参数区域 -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="安装参数" 
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>
                
                <!-- 参数列表 -->
                <ItemsControl ItemsSource="{Binding ParameterViewModels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,15" Padding="10"
                                    Background="{DynamicResource MaterialDesign50}"
                                    CornerRadius="4">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- 参数标题 -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" 
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="center"/>
                                        <TextBlock Text="*" 
                                                   Foreground="Red"
                                                   Margin="2,0,0,0"
                                                   Visibility="{Binding Required, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <TextBlock Text="{Binding Hint}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Margin="5,0,0,0"/>
                                    </StackPanel>
                                    
                                    <!-- 参数描述 -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Margin="0,3,0,5"
                                               Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>
                                    
                                    <!-- 输入控件 -->
                                    <Grid Grid.Row="2">
                                        <!-- 文本输入 -->
                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                                 Visibility="{Binding Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Text}"/>

                                        <!-- 密码输入 -->
                                        <PasswordBox materialDesign:HintAssist.Hint="请输入密码"
                                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                                     materialDesign:HintAssist.Foreground="{DynamicResource SecondaryTextBrush}"
                                                     materialDesign:HintAssist.HintOpacity="0.9"
                                                     materialDesign:PasswordBoxAssist.Password="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     Visibility="{Binding Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Password}"/>

                                        <!-- 数字输入 -->
                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                                 Visibility="{Binding Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Number}"/>

                                        <!-- 端口输入 -->
                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource DarkTextBoxStyle}"
                                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                                 Visibility="{Binding Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Port}"/>

                                        <!-- 路径输入 -->
                                        <Grid Visibility="{Binding Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Path}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource DarkTextBoxStyle}"
                                                     Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <Button Grid.Column="1"
                                                    Content="选择"
                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                    Command="{Binding BrowsePathCommand}"
                                                    Margin="5,0,0,0"/>
                                        </Grid>

                                        <!-- 布尔值复选框 -->
                                        <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding Type, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Boolean}">
                                            <CheckBox IsChecked="{Binding BoolValue, UpdateSourceTrigger=PropertyChanged}"
                                                      Content="启用"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
        
        <!-- 按钮区域 -->
        <UniformGrid Grid.Row="5" Rows="1" Columns="2" Margin="0,15,0,0">
            <Button Content="取消" 
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding CancelCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="确认" 
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding ConfirmCommand}"
                    IsDefault="True"
                    HorizontalAlignment="Stretch"/>
        </UniformGrid>
    </Grid>
</Window>
