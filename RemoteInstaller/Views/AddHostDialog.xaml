<Window x:Class="RemoteInstaller.Views.AddHostDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}"
        Height="650" Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="{Binding DialogTitle}"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <!-- 表单内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 主机名称 -->
                <TextBox Text="{Binding HostName, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="主机名称"
                         materialDesign:HintAssist.HelperText="输入便于识别的主机名称"
                         Margin="0,0,0,15"/>

                <!-- IP 地址 -->
                <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="主机地址"
                         materialDesign:HintAssist.HelperText="输入服务器地址，例如 192.168.1.100"
                         Margin="0,0,0,15"/>

                <!-- 端口和用户名 -->
                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="端口"
                             materialDesign:HintAssist.HelperText="默认 22"
                             Margin="0,0,10,0"/>

                    <TextBox Grid.Column="1"
                             Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="用户名"
                             materialDesign:HintAssist.HelperText="登录用户名"
                             Width="150"/>
                </Grid>

                <!-- 认证方式 -->
                <materialDesign:Card Margin="0,0,0,15">
                    <StackPanel Margin="15">
                        <TextBlock Text="认证方式"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton Content="密码认证"
                                         GroupName="AuthType"
                                         IsChecked="{Binding AuthType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Password}"
                                         Margin="0,0,20,0"/>
                            <RadioButton Content="私钥认证"
                                         GroupName="AuthType"
                                         IsChecked="{Binding AuthType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=PrivateKey}"/>
                        </StackPanel>

                        <!-- 密码输入 -->
                        <PasswordBox x:Name="PasswordBox"
                                     materialDesign:HintAssist.Hint="密码"
                                     Visibility="{Binding AuthType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Password}"/>

                        <!-- 私钥路径 -->
                        <Grid Visibility="{Binding AuthType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=PrivateKey}"
                                    Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding KeyPath, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="私钥文件路径"
                                     IsReadOnly="True"/>
                            <Button Grid.Column="1"
                                    Content="浏览"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding BrowseKeyPathCommand}"
                                    Margin="5,0,0,0"
                                    Height="32"
                                    Padding="10,0"/>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- 操作系统类型（只读，连接后自动填充） -->
                <TextBox Text="{Binding OsTypeDisplay, Mode=OneWay}"
                         materialDesign:HintAssist.Hint="操作系统类型"
                         materialDesign:HintAssist.HelperText="连接测试成功后自动识别"
                         IsReadOnly="True"
                         Margin="0,0,0,15"
                         Background="{DynamicResource MaterialDesignBackground}"/>

                <!-- 分组 -->
                <TextBox Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="分组名称"
                         materialDesign:HintAssist.HelperText="可选，用于分组管理服务器"
                         Margin="0,0,0,15"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 测试结果 -->
        <Border Grid.Row="2"
                Margin="0,15,0,15"
                Padding="10"
                CornerRadius="4"
                Background="{Binding TestSuccess, Converter={StaticResource BoolToBackgroundConverter}}">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center"
                        Visibility="{Binding TestResult, Converter={StaticResource StringToVisibilityConverter}}">
                <materialDesign:PackIcon Kind="{Binding TestSuccess, Converter={StaticResource BoolToIconConverter}}"
                                         Width="20" Height="20"
                                         Foreground="{Binding TestSuccess, Converter={StaticResource BoolToColorConverter2}}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>
                <TextBlock Text="{Binding TestResult}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- 按钮 -->
        <UniformGrid Grid.Row="3" Rows="1" Columns="3" Margin="0,10,0,0">
            <Button Content="测试连接"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding TestConnectionCommand}"
                    IsEnabled="{Binding CanTestConnection}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="取消"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding CancelCommand}"
                    HorizontalAlignment="Stretch"/>
            <Button Content="保存"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}"
                    HorizontalAlignment="Stretch"/>
        </UniformGrid>
    </Grid>
</Window>
