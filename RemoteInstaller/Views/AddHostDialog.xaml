<Window x:Class="RemoteInstaller.Views.AddHostDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}"
        Height="580"
        Width="500"
        MinWidth="430"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="{DynamicResource MaterialDesignPaper}">

    <Window.Resources>
        <Style x:Key="CompactTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
        </Style>

        <Style x:Key="CompactPasswordBoxStyle"
               TargetType="PasswordBox"
               BasedOn="{StaticResource {x:Type PasswordBox}}">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="materialDesign:HintAssist.IsFloating" Value="True"/>
        </Style>

        <Style x:Key="CompactHintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource MaterialDesignBodyDisabled}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="{Binding DialogTitle}"
                   FontSize="17"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <!-- 表单内容 -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <!-- 主机名称 -->
                <TextBox Text="{Binding HostName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource CompactTextBoxStyle}"
                         materialDesign:HintAssist.Hint="主机名称"/>

                <!-- IP 地址 -->
                <TextBox Text="{Binding IpAddress, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource CompactTextBoxStyle}"
                         materialDesign:HintAssist.Hint="主机地址"/>

                <!-- 端口和用户名 -->
                <StackPanel Margin="0,0,0,2">
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}"
                             materialDesign:HintAssist.Hint="端口"/>

                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource CompactTextBoxStyle}"
                             materialDesign:HintAssist.Hint="用户名"/>
                </StackPanel>

                <!-- 认证方式 -->
                <materialDesign:Card Margin="0,0,0,6">
                    <StackPanel Margin="8">
                        <TextBlock Text="认证方式"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>

                        <WrapPanel Margin="0,0,0,4">
                            <RadioButton Content="密码认证"
                                         GroupName="AuthType"
                                         IsChecked="{Binding AuthType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Password}"
                                         Margin="0,0,16,4"/>
                            <RadioButton Content="私钥认证"
                                         GroupName="AuthType"
                                         IsChecked="{Binding AuthType, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=PrivateKey}"
                                         Margin="0,0,0,4"/>
                        </WrapPanel>

                        <!-- 密码输入 -->
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource CompactPasswordBoxStyle}"
                                     materialDesign:HintAssist.Hint="密码"
                                     Visibility="{Binding AuthType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=Password}"/>

                        <!-- 私钥路径 -->
                        <Grid Visibility="{Binding AuthType, Converter={StaticResource EnumToVisibilityConverter}, ConverterParameter=PrivateKey}"
                              Margin="0,4,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBox Grid.Row="0"
                                     Text="{Binding KeyPath, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource CompactTextBoxStyle}"
                                     materialDesign:HintAssist.Hint="私钥文件路径"
                                     IsReadOnly="True"/>
                            <WrapPanel Grid.Row="1" Margin="0,6,0,0">
                                <Button Content="浏览"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Command="{Binding BrowseKeyPathCommand}"
                                        Padding="10,5"/>
                            </WrapPanel>
                        </Grid>
                    </StackPanel>
                </materialDesign:Card>

                <!-- 操作系统类型（只读，连接后自动填充） -->
                <TextBox Text="{Binding OsTypeDisplay, Mode=OneWay}"
                         Style="{StaticResource CompactTextBoxStyle}"
                         materialDesign:HintAssist.Hint="操作系统类型"
                         IsReadOnly="True"
                         Background="{DynamicResource MaterialDesignBackground}"/>
                <TextBlock Text="连接测试成功后自动识别操作系统类型"
                           Style="{StaticResource CompactHintTextStyle}"/>

                <!-- 分组 -->
                <TextBox Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource CompactTextBoxStyle}"
                         materialDesign:HintAssist.Hint="分组名称"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 测试结果 -->
        <Border Grid.Row="2"
                Margin="0,8,0,8"
                Padding="8,6"
                CornerRadius="4"
                Background="{Binding TestSuccess, Converter={StaticResource BoolToBackgroundConverter}}">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Visibility="{Binding TestResult, Converter={StaticResource StringToVisibilityConverter}}">
                <materialDesign:PackIcon Kind="{Binding TestSuccess, Converter={StaticResource BoolToIconConverter}}"
                                         Width="20"
                                         Height="20"
                                         Foreground="{Binding TestSuccess, Converter={StaticResource BoolToColorConverter2}}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"/>
                <TextBlock Text="{Binding TestResult}"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- 按钮 -->
        <WrapPanel Grid.Row="3" Margin="0,4,0,0" HorizontalAlignment="Right">
            <Button Content="测试连接"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding TestConnectionCommand}"
                    IsEnabled="{Binding CanTestConnection}"
                    Margin="0,0,8,0"
                    Padding="10,5"/>
            <Button Content="取消"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,8,0"
                    Padding="10,5"/>
            <Button Content="保存"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}"
                    Margin="0,0,0,0"
                    Padding="10,5"/>
        </WrapPanel>
    </Grid>
</Window>
