<Window
    x:Class="RemoteInstaller.Views.Dialogs.InstallProgressDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:local="clr-namespace:RemoteInstaller"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="安装进度"
    Width="700" Height="500"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanMinimize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding Title}" 
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource MaterialDesignBody}"/>
            <Button Grid.Column="1"
                    Style="{StaticResource MaterialDesignToolButton}"
                    ToolTipService.ToolTip="最小化"
                    Margin="16,0,0,0"
                    Command="{Binding MinimizeCommand}">
                <materialDesign:PackIcon Kind="ArrowDown"/>
            </Button>
        </Grid>

        <!-- 步骤进度 -->
        <Grid Grid.Row="1" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <!-- 步骤 1: 配置参数 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <materialDesign:PackIcon Kind="CheckCircle"
                                             Width="16" Height="16"
                                             Foreground="{DynamicResource SuccessBrush}"
                                             Visibility="{Binding IsStep1Complete, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <materialDesign:PackIcon Kind="CircleOutline"
                                             Width="16" Height="16"
                                             Foreground="{DynamicResource SecondaryTextBrush}"
                                             Visibility="{Binding IsStep1Complete, Converter={StaticResource InverseBoolConverter}}"/>
                    <TextBlock Text="配置参数" 
                               FontSize="11" Margin="4,0,0,0"
                               Foreground="{Binding IsStep1Complete, Converter={StaticResource StepStatusToColorConverter}}"/>
                </StackPanel>
                <materialDesign:PackIcon Kind="ChevronRight" Width="12" Height="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                
                <!-- 步骤 2: 上传文件 -->
                <StackPanel Orientation="Horizontal" Margin="12,0,12,0">
                    <materialDesign:PackIcon Kind="CheckCircle"
                                             Width="16" Height="16"
                                             Foreground="{DynamicResource SuccessBrush}"
                                             Visibility="{Binding IsStep2Complete, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <materialDesign:PackIcon Kind="CircleOutline"
                                             Width="16" Height="16"
                                             Foreground="{DynamicResource SecondaryTextBrush}"
                                             Visibility="{Binding IsStep2Complete, Converter={StaticResource InverseBoolConverter}}"/>
                    <TextBlock Text="上传文件" 
                               FontSize="11" Margin="4,0,0,0"
                               Foreground="{Binding IsStep2Complete, Converter={StaticResource StepStatusToColorConverter}}"/>
                </StackPanel>
                <materialDesign:PackIcon Kind="ChevronRight" Width="12" Height="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                
                <!-- 步骤 3: 执行安装 -->
                <StackPanel Orientation="Horizontal" Margin="12,0,12,0">
                    <materialDesign:PackIcon Kind="CheckCircle"
                                             Width="16" Height="16"
                                             Foreground="{DynamicResource SuccessBrush}"
                                             Visibility="{Binding IsStep3Complete, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <materialDesign:PackIcon Kind="Loading"
                                             Width="16" Height="16"
                                             Foreground="{DynamicResource AccentBrush}"
                                             Visibility="{Binding IsStep3Running, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <materialDesign:PackIcon Kind="CircleOutline"
                                             Width="16" Height="16"
                                             Foreground="{DynamicResource SecondaryTextBrush}"
                                             Visibility="{Binding IsStep3Running, Converter={StaticResource InverseBoolConverter}}"/>
                    <TextBlock Text="执行安装" 
                               FontSize="11" FontWeight="{Binding IsStep3Running, Converter={StaticResource StepStatusToWeightConverter}}"
                               Margin="4,0,0,0"
                               Foreground="{Binding IsStep3Complete, Converter={StaticResource StepStatusToColorConverter}}"/>
                </StackPanel>
                <materialDesign:PackIcon Kind="ChevronRight" Width="12" Height="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                
                <!-- 步骤 4: 完成 -->
                <StackPanel Orientation="Horizontal" Margin="12,0,0,0">
                    <materialDesign:PackIcon Kind="CheckCircle"
                                             Width="16" Height="16"
                                             Foreground="{DynamicResource SuccessBrush}"
                                             Visibility="{Binding IsStep4Complete, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <materialDesign:PackIcon Kind="CircleOutline"
                                             Width="16" Height="16"
                                             Foreground="{DynamicResource SecondaryTextBrush}"
                                             Visibility="{Binding IsStep4Complete, Converter={StaticResource InverseBoolConverter}}"/>
                    <TextBlock Text="完成" 
                               FontSize="11" Margin="4,0,0,0"
                               Foreground="{Binding IsStep4Complete, Converter={StaticResource StepStatusToColorConverter}}"/>
                </StackPanel>
            </StackPanel>
            <!-- 当前阶段名称 -->
            <TextBlock Grid.Column="1"
                       Text="{Binding CurrentStage}"
                       FontSize="13" FontWeight="Medium"
                       Foreground="{DynamicResource AccentBrush}"/>
        </Grid>

        <!-- 进度条 -->
        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ProgressBar Grid.Column="0"
                         Value="{Binding Progress}"
                         Minimum="0" Maximum="100"
                         Height="8"
                         Background="{DynamicResource SurfaceElevatedBrush}"
                         Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock Grid.Column="1"
                       Text="{Binding Progress, StringFormat={}{0:0}%}"
                       VerticalAlignment="Center"
                       Margin="12,0,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource MaterialDesignBody}"/>
        </Grid>

        <!-- 操作按钮 -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Content="⏸️ 暂停"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding PauseCommand}"
                    IsEnabled="{Binding IsRunning}"
                    Visibility="{Binding IsPaused, Converter={StaticResource InverseBoolConverter}}"/>
            <Button Grid.Column="1"
                    Content="▶️ 继续"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Command="{Binding ResumeCommand}"
                    IsEnabled="{Binding IsPaused}"
                    Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <Button Grid.Column="2"
                    Content="❌ 取消"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Background="{DynamicResource ErrorBrush}"
                    Foreground="White"
                    Command="{Binding CancelCommand}"
                    IsEnabled="{Binding IsRunning}"
                    Margin="8,0,0,0"/>
        </Grid>

        <!-- 日志输出 - 按级别着色 -->
        <Border Grid.Row="4"
                Background="{DynamicResource SurfaceBrush}"
                CornerRadius="8" Padding="16"
                Margin="0,16,0,0">
            <ScrollViewer x:Name="LogScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding LogEntries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       TextWrapping="Wrap">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- 日志操作 -->
        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Content="🗑️ 清空日志"
                    Style="{StaticResource MaterialDesignToolButton}"
                    ToolTip="清空日志"
                    Command="{Binding ClearLogCommand}"/>
            <Button Grid.Column="1"
                    Content="💾 保存日志"
                    Style="{StaticResource MaterialDesignToolButton}"
                    ToolTip="保存日志到文件"
                    Command="{Binding SaveLogCommand}"
                    Margin="8,0,0,0"/>
            <CheckBox Grid.Column="3"
                      Content="自动滚动"
                      IsChecked="{Binding AutoScroll}"
                      VerticalAlignment="Center"
                      FontSize="11"/>
        </Grid>
    </Grid>
</Window>
