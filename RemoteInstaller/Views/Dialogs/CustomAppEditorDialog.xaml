<Window x:Class="RemoteInstaller.Views.Dialogs.CustomAppEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding DialogTitle}"
        Width="1000"
        Height="750"
        MinWidth="900"
        MinHeight="650"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusLarge}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding DialogTitle}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Text="按 SUPPORT 内容结构配置自定义应用"
                               Margin="0,4,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="12" Height="12" Margin="0,0,8,0" Fill="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="{Binding AppType, StringFormat='类型: {0}'}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <WrapPanel Grid.Row="1" Margin="0,12,0,0">
            <Button Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"
                    IsDefault="True"
                    Padding="16,8"
                    Margin="0,0,8,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ContentSaveOutline" Width="16" Height="16"/>
                    <TextBlock Margin="6,0,0,0" Text="保存"/>
                </StackPanel>
            </Button>
            <Button Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Padding="16,8"
                    Margin="0,0,8,8">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                    <TextBlock Margin="6,0,0,0" Text="取消"/>
                </StackPanel>
            </Button>
        </WrapPanel>

        <TabControl Grid.Row="2" Margin="0,12,0,0" Style="{StaticResource MaterialDesignTabControl}">
            <TabItem Header="上传部署">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="基础信息"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBox Grid.Column="0"
                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="应用名称"/>
                                    <TextBox Grid.Column="1"
                                             Margin="8,0,0,0"
                                             Text="{Binding Icon, UpdateSourceTrigger=PropertyChanged}"
                                             materialDesign:HintAssist.Hint="图标"/>
                                </Grid>

                                <TextBox Margin="0,10,0,0"
                                         Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="描述"/>

                                <ComboBox Margin="0,10,0,0"
                                          SelectedValue="{Binding AppType, UpdateSourceTrigger=PropertyChanged}"
                                          SelectedValuePath="Tag"
                                          materialDesign:HintAssist.Hint="部署类型">
                                    <ComboBoxItem Content="SUPPORT（支持部署）" Tag="SUPPORT"/>
                                    <ComboBoxItem Content="GENERIC（通用部署）" Tag="GENERIC"/>
                                    <ComboBoxItem Content="CUSTOM（自定义部署）" Tag="CUSTOM"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="部署路径"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>

                                <TextBox Margin="0,12,0,0"
                                         Text="{Binding RemoteDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="远程目录"/>

                                <TextBox Margin="0,10,0,0"
                                         Text="{Binding RemoteFrontendDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="前端远程目录"/>

                                <TextBox Margin="0,10,0,0"
                                         Text="{Binding PidFilePath, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="PID 文件路径"/>

                                <TextBox Margin="0,10,0,0"
                                         Text="{Binding ConfigDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="配置目录"/>

                                <TextBox Margin="0,10,0,0"
                                         Text="{Binding ConfigFileName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="配置文件名"/>

                                <TextBox Margin="0,10,0,0"
                                         Text="{Binding ConfigFilePath, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="配置文件路径（可选）"/>

                                <TextBox Margin="0,10,0,0"
                                         Text="{Binding LogDirectory, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="日志目录"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="脚本编辑">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}" Margin="0,0,8,0">
                            <StackPanel>
                                <TextBlock Text="启动命令"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBox Margin="0,12,0,0"
                                         Text="{Binding StartCommand, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="启动命令"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="220"
                                         FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource SectionCardStyle}" Margin="8,0,0,0">
                            <StackPanel>
                                <TextBlock Text="停止命令"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBox Margin="0,12,0,0"
                                         Text="{Binding StopCommand, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="停止命令"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         MinHeight="220"
                                         FontFamily="Consolas"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="日志查看">
                <Grid Margin="12">
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="状态与校验信息"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <TextBlock Text="保存校验失败时，这里会显示错误信息。"
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBox Margin="0,12,0,0"
                                     Text="{Binding ErrorMessage}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="260"
                                     Background="{DynamicResource SurfaceBrush}"
                                     Foreground="{DynamicResource ErrorBrush}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="3" Style="{StaticResource SectionCardStyle}" Margin="0,12,0,0" Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="当前状态"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Margin="0,4,0,0"
                               FontSize="12">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="{Binding ErrorMessage}"/>
                                <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                        <Setter Property="Text" Value="就绪"/>
                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <ProgressBar Grid.Column="1"
                             Value="0"
                             Margin="16,0,16,0"
                             Height="8"
                             VerticalAlignment="Center"/>

                <Button Grid.Column="2"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding CancelCommand}"
                        IsCancel="True"
                        Padding="14,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                        <TextBlock Margin="6,0,0,0" Text="关闭"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
