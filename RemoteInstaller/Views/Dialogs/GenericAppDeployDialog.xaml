<Window
    x:Class="RemoteInstaller.Views.Dialogs.GenericAppDeployDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:local="clr-namespace:RemoteInstaller.Models"
    Title="{Binding WindowTitle}"
    Width="1100"
    Height="800"
    MinWidth="1000"
    MinHeight="700"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    Background="{DynamicResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Padding="18"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusLarge}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding WindowTitle}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="支持上传文件/目录到目标服务器，并管理启动/停止脚本"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Padding="10,6"
                        Background="{DynamicResource AccentBrush}"
                        CornerRadius="{StaticResource CornerRadiusSmall}"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding HostDisplay}"
                               Foreground="White"
                               FontWeight="Medium"/>
                </Border>
            </Grid>
        </Border>

        <!-- 配置区域 -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：本地来源 -->
            <Border Grid.Column="0"
                    Margin="0,0,10,0"
                    Padding="16"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusLarge}">
                <StackPanel>
                    <TextBlock Text="本地来源"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Margin="0,4,0,14"
                               Text="可选择文件，也可直接选择整个文件夹上传"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <TextBlock Text="应用名称" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Margin="0,6,0,12"
                             Text="{Binding ApplicationName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="本地文件或文件夹" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="{Binding LocalSourcePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="12,6"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding BrowseFileCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileOutline" Width="14" Height="14"/>
                                <TextBlock Margin="4,0,0,0" Text="文件"/>
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Margin="8,0,0,0"
                                Padding="12,6"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding BrowseFolderCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Folder" Width="14" Height="14"/>
                                <TextBlock Margin="4,0,0,0" Text="文件夹"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border Margin="0,12,0,0"
                            Padding="12,10"
                            Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="{StaticResource CornerRadiusMedium}">
                        <StackPanel>
                            <TextBlock Text="来源信息"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding SourceSummary}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Border>

                    <CheckBox Margin="0,14,0,0"
                              IsChecked="{Binding PreserveTopLevelDirectory}"
                              Content="上传文件夹时保留顶层目录名"/>
                </StackPanel>
            </Border>

            <!-- 右侧：远程目标 -->
            <Border Grid.Column="1"
                    Margin="10,0,0,0"
                    Padding="16"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusLarge}">
                <StackPanel>
                    <TextBlock Text="远程目标"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Margin="0,4,0,14"
                               Text="配置目标服务器上的部署路径和命令"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <TextBlock Text="远程目录" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding RemoteDirectory, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding LoadDirectoryCommand}"
                                Padding="10,6">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FolderOpen" Width="14" Height="14"/>
                                <TextBlock Margin="4,0,0,0" Text="加载"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- 远程目录结构 -->
                    <Border Margin="0,8,0,0"
                            MaxHeight="200"
                            Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="{StaticResource CornerRadiusMedium}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TreeView Grid.Row="0"
                                      ItemsSource="{Binding DirectoryItems}"
                                      SelectedItemChanged="TreeView_SelectedItemChanged"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Margin="4">
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate DataType="{x:Type local:DirectoryItem}" ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="2,3">
                                            <materialDesign:PackIcon Width="16" Height="16" VerticalAlignment="Center">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Kind" Value="File"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDirectory}" Value="True">
                                                                <Setter Property="Kind" Value="Folder"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource WarningBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                            <TextBlock Text="{Binding Name}"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.Resources>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        <EventSetter Event="Collapsed" Handler="TreeViewItem_Collapsed"/>
                                        <EventSetter Event="Expanded" Handler="TreeViewItem_Expanded"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                            </TreeView>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8,4,8,8">
                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ReplaceFileCommand}"
                                        Padding="12,6"
                                        IsEnabled="{Binding SelectedDirectoryItem, Converter={StaticResource NullToBoolConverter}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FileReplace" Width="14" Height="14"/>
                                        <TextBlock Margin="4,0,0,0" Text="替换文件"/>
                                    </StackPanel>
                                </Button>
                                <TextBlock Text="{Binding SelectedDirectoryItem.RemotePath, StringFormat='已选择: {0}'}"
                                           Margin="12,0,0,0"
                                           VerticalAlignment="Center"
                                           FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <TextBlock Text="启动命令" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,12,0,0"/>
                    <TextBox Margin="0,6,0,6"
                             Text="{Binding StartCommand, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Mono, Consolas"/>

                    <TextBlock Text="停止命令" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Margin="0,6,0,6"
                             Text="{Binding StopCommand, UpdateSourceTrigger=PropertyChanged}"
                             FontFamily="Cascadia Mono, Consolas"/>

                    <TextBlock Text="配置文件路径" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding ConfigFilePath, UpdateSourceTrigger=PropertyChanged}"/>

                    <Border Margin="0,12,0,0"
                            Padding="10"
                            Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="{StaticResource CornerRadiusMedium}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="配置项"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           VerticalAlignment="Center"/>

                                <WrapPanel Grid.Column="1">
                                    <WrapPanel.Style>
                                        <Style TargetType="WrapPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRawTextMode}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </WrapPanel.Style>
                                    <Button Padding="10,6"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding AddConfigItemCommand}">
                                        <TextBlock Text="新增项"/>
                                    </Button>
                                    <Button Margin="8,0,0,0"
                                            Padding="10,6"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding RemoveSelectedConfigItemCommand}">
                                        <TextBlock Text="删除选中项"/>
                                    </Button>
                                </WrapPanel>
                            </Grid>

                            <DataGrid Grid.Row="1"
                                      Margin="0,8,0,0"
                                      MinHeight="180"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      IsReadOnly="{Binding IsBusy}"
                                      ItemsSource="{Binding ConfigItems}"
                                      SelectedItem="{Binding SelectedConfigItem, Mode=TwoWay}">
                                <DataGrid.Style>
                                    <Style TargetType="DataGrid">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsYamlMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsRawTextMode}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGrid.Style>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="2*"
                                                        Header="Key"
                                                        Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                                    <DataGridTextColumn Width="3*"
                                                        Header="Value"
                                                        Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TreeView Grid.Row="1"
                                      Margin="0,8,0,0"
                                      MinHeight="180"
                                      ItemsSource="{Binding YamlTreeNodes}"
                                      SelectedItemChanged="YamlConfigTreeView_SelectedItemChanged"
                                      Background="{DynamicResource SurfaceLightBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      BorderThickness="1"
                                      Foreground="{DynamicResource PrimaryTextBrush}">
                                <TreeView.Style>
                                    <Style TargetType="TreeView">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsYamlMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.Style>
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="MinHeight" Value="24"/>
                                        <Setter Property="Padding" Value="2,0,2,0"/>
                                        <Setter Property="Margin" Value="0,1,0,1"/>
                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                        <Grid Margin="0,1" HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="3*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       Text="{Binding DisplayKey}"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=Foreground}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Children.Count}" Value="0">
                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBox Grid.Column="1"
                                                     Margin="8,0,0,0"
                                                     VerticalContentAlignment="Center"
                                                     MinHeight="24"
                                                     Padding="6,2"
                                                     Text="{Binding Value, UpdateSourceTrigger=LostFocus}"
                                                     IsEnabled="{Binding IsEditable}"
                                                     Foreground="{DynamicResource PrimaryTextBrush}"
                                                     Background="{DynamicResource SurfaceBrush}"
                                                     BorderBrush="{DynamicResource BorderBrush}"
                                                     CaretBrush="{DynamicResource AccentBrush}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding Children.Count}" Value="0"/>
                                                                    <Condition Binding="{Binding IsEditable}" Value="True"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </Grid>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>

                            <TextBox Grid.Row="1"
                                     Margin="0,8,0,0"
                                     MinHeight="180"
                                     Text="{Binding ConfigFileContent, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Cascadia Mono, Consolas"
                                     FontSize="12"
                                     Padding="10">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRawTextMode}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                                <Button Padding="10,6"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding LoadConfigCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Download" Width="14" Height="14"/>
                                        <TextBlock Margin="4,0,0,0" Text="加载配置"/>
                                    </StackPanel>
                                </Button>
                                <Button Margin="8,0,0,0"
                                        Padding="10,6"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SaveConfigCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Upload" Width="14" Height="14"/>
                                        <TextBlock Margin="4,0,0,0" Text="保存配置"/>
                                    </StackPanel>
                                </Button>
                            </WrapPanel>
                        </Grid>
                    </Border>

                    <Border Margin="0,12,0,0"
                            Padding="12,10"
                            Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="{StaticResource CornerRadiusMedium}">
                        <StackPanel>
                            <TextBlock Text="最终上传路径"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock Margin="0,4,0,0"
                                       Text="{Binding RemoteTargetPreview}"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 脚本编辑区域 -->
        <Border Grid.Row="2"
                Margin="0,16,0,0"
                Padding="16"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusLarge}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="脚本编辑"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Margin="0,0,0,12"/>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 启动脚本 -->
                    <Border Grid.Column="0"
                            Margin="0,0,8,0"
                            Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="{StaticResource CornerRadiusMedium}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,12,12,8">
                                <materialDesign:PackIcon Kind="ScriptText" Width="16" Height="16"
                                                         Foreground="{DynamicResource AccentBrush}"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="启动脚本 (start.sh)"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBox Grid.Row="1"
                                     Margin="12,0,12,12"
                                     Text="{Binding StartScriptContent, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Cascadia Mono, Consolas"
                                     FontSize="12"
                                     Background="Transparent"
                                     BorderThickness="0"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,0,12,12">
                                <Button Padding="12,6"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding LoadStartScriptCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Download" Width="14" Height="14"/>
                                        <TextBlock Margin="4,0,0,0" Text="加载"/>
                                    </StackPanel>
                                </Button>
                                <Button Margin="8,0,0,0"
                                        Padding="12,6"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SaveStartScriptCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Upload" Width="14" Height="14"/>
                                        <TextBlock Margin="4,0,0,0" Text="保存"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 停止脚本 -->
                    <Border Grid.Column="1"
                            Margin="8,0,0,0"
                            Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="{StaticResource CornerRadiusMedium}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,12,12,8">
                                <materialDesign:PackIcon Kind="ScriptText" Width="16" Height="16"
                                                         Foreground="{DynamicResource WarningBrush}"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="停止脚本 (stop.sh)"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <TextBox Grid.Row="1"
                                     Margin="12,0,12,12"
                                     Text="{Binding StopScriptContent, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontFamily="Cascadia Mono, Consolas"
                                     FontSize="12"
                                     Background="Transparent"
                                     BorderThickness="0"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="12,0,12,12">
                                <Button Padding="12,6"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding LoadStopScriptCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Download" Width="14" Height="14"/>
                                        <TextBlock Margin="4,0,0,0" Text="加载"/>
                                    </StackPanel>
                                </Button>
                                <Button Margin="8,0,0,0"
                                        Padding="12,6"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding SaveStopScriptCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Upload" Width="14" Height="14"/>
                                        <TextBlock Margin="4,0,0,0" Text="保存"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- 底部区域 -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 操作按钮 -->
            <WrapPanel Grid.Row="0">
                <Button Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding UploadOnlyCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloudUpload" Width="16" Height="16"/>
                        <TextBlock Margin="6,0,0,0" Text="仅上传"/>
                    </StackPanel>
                </Button>

                <Button Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding UploadAndStartCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CloudUpload" Width="16" Height="16"/>
                        <TextBlock Margin="6,0,0,0" Text="上传并启动"/>
                    </StackPanel>
                </Button>

                <Button Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding StartApplicationCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Play" Width="16" Height="16"/>
                        <TextBlock Margin="6,0,0,0" Text="执行启动命令"/>
                    </StackPanel>
                </Button>

                <Button Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding EditConfigCommand}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileEditOutline" Width="16" Height="16"/>
                        <TextBlock Margin="6,0,0,0" Text="编辑配置"/>
                    </StackPanel>
                </Button>

                <Button Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource ToolButtonStyle}"
                        Command="{Binding CancelOperationCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Stop" Width="16" Height="16"/>
                        <TextBlock Margin="6,0,0,0" Text="取消"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <!-- 状态和日志 -->
            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding StatusMessage}"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>

                <ProgressBar Grid.Row="1"
                             Margin="0,8,0,0"
                             Height="6"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding UploadProgress}"
                             Foreground="{DynamicResource AccentBrush}"
                             Background="{DynamicResource SurfaceLightBrush}"/>

                <TextBox Grid.Row="2"
                         Margin="0,8,0,0"
                         Text="{Binding ActivityLog}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="12"
                         Background="{DynamicResource SurfaceLightBrush}"
                         BorderThickness="0"
                         Padding="12"/>
            </Grid>
        </Grid>
    </Grid>
    </ScrollViewer>
</Window>
