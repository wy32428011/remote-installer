<Window x:Class="RemoteInstaller.Views.Dialogs.TerminalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="{Binding WindowTitle}"
        Width="1120"
        Height="760"
        MinWidth="900"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource DarkBackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <ContextMenu x:Key="TerminalContextMenu"
                     Style="{StaticResource DarkContextMenuStyle}"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Header="复制" Command="ApplicationCommands.Copy" Style="{StaticResource DarkMenuItemStyle}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="ContentCopy"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="全选" Command="ApplicationCommands.SelectAll" Style="{StaticResource DarkMenuItemStyle}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="SelectAll"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="导出日志" Command="{Binding ExportOutputCommand}" Style="{StaticResource DarkMenuItemStyle}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="Export"/>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="清空输出" Command="{Binding ClearOutputCommand}" Style="{StaticResource DarkMenuItemStyle}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="Delete"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="QuickActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Foreground" Value="{DynamicResource DarkPrimaryTextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource DarkSurfaceLightBrush}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Border Width="44"
                        Height="44"
                        CornerRadius="14"
                        Background="{DynamicResource DarkSurfaceElevatedBrush}"
                        BorderBrush="{DynamicResource DarkBorderLightBrush}"
                        BorderThickness="1">
                    <materialDesign:PackIcon Kind="Console"
                                             Width="22"
                                             Height="22"
                                             Foreground="{DynamicResource CustomPrimaryBrush}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="14,0,0,0">
                    <TextBlock Text="{Binding WindowTitle}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource DarkPrimaryTextBrush}"/>
                    <TextBlock Text="支持会话状态、快捷操作和实时输出的交互终端。"
                               FontSize="12"
                               Foreground="{DynamicResource DarkSecondaryTextBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource MaterialDesignToolButton}"
                    ToolTip="关闭"
                    Click="CloseButton_Click">
                <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="16"
                Background="{DynamicResource DarkSurfaceBrush}"
                BorderBrush="{DynamicResource DarkBorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel>
                    <Border Margin="0,0,10,10"
                            Padding="10,6"
                            Background="{Binding IsConnected, Converter={StaticResource BoolToBackgroundConverter}}"
                            CornerRadius="8">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8"
                                     Height="8"
                                     Fill="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"
                                     VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding StatusMessage}"
                                       Margin="8,0,0,0"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="10,6" Background="{DynamicResource DarkSurfaceElevatedBrush}" CornerRadius="8">
                        <TextBlock>
                            <Run Text="主机："/>
                            <Run Text="{Binding HostViewModel.Name}"/>
                        </TextBlock>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="10,6" Background="{DynamicResource DarkSurfaceElevatedBrush}" CornerRadius="8">
                        <TextBlock>
                            <Run Text="地址："/>
                            <Run Text="{Binding HostViewModel.IpAddress}"/>
                        </TextBlock>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="10,6" Background="{DynamicResource DarkSurfaceElevatedBrush}" CornerRadius="8">
                        <TextBlock>
                            <Run Text="系统："/>
                            <Run Text="{Binding OperatingSystemLabel}"/>
                        </TextBlock>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="10,6" Background="{DynamicResource DarkSurfaceElevatedBrush}" CornerRadius="8">
                        <TextBlock>
                            <Run Text="终端："/>
                            <Run Text="{Binding ShellLabel}"/>
                        </TextBlock>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="10,6" Background="{DynamicResource DarkSurfaceElevatedBrush}" CornerRadius="8">
                        <TextBlock>
                            <Run Text="目录："/>
                            <Run Text="{Binding CurrentDirectory}"/>
                        </TextBlock>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="10,6" Background="{DynamicResource DarkSurfaceElevatedBrush}" CornerRadius="8">
                        <TextBlock>
                            <Run Text="退出码："/>
                            <Run Text="{Binding LastExitCode}"/>
                        </TextBlock>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="10,6" Background="{DynamicResource DarkSurfaceElevatedBrush}" CornerRadius="8">
                        <TextBlock>
                            <Run Text="命令数："/>
                            <Run Text="{Binding ExecutedCommandCount}"/>
                        </TextBlock>
                    </Border>

                    <Border Margin="0,0,10,10" Padding="10,6" Background="{DynamicResource DarkSurfaceElevatedBrush}" CornerRadius="8">
                        <TextBlock>
                            <Run Text="输出量："/>
                            <Run Text="{Binding OutputSize}"/>
                        </TextBlock>
                    </Border>
                </WrapPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Button Style="{StaticResource ToolButtonStyle}"
                            Command="{Binding ReconnectCommand}"
                            IsEnabled="{Binding CanReconnect}"
                            ToolTip="重新连接会话">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"/>
                            <TextBlock Text="重连" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolButtonStyle}"
                            Command="{Binding ExportOutputCommand}"
                            Margin="8,0,0,0"
                            ToolTip="导出日志">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Export" Width="16" Height="16"/>
                            <TextBlock Text="导出" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Padding="14"
                Background="{DynamicResource DarkSurfaceBrush}"
                BorderBrush="{DynamicResource DarkBorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <StackPanel>
                <TextBlock Text="快捷操作"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource DarkPrimaryTextBrush}"/>
                <TextBlock Text="无需手输即可执行常用主机检查，命令仍在当前会话内运行。"
                           Margin="0,4,0,12"
                           FontSize="11"
                           Foreground="{DynamicResource DarkSecondaryTextBrush}"/>

                <WrapPanel Visibility="{Binding IsLinuxHost, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="pwd" Content="当前目录"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="ls -la" Content="列表"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="df -h" Content="磁盘"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="free -h" Content="内存"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="ps -ef | head -20" Content="进程"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="systemctl --failed --no-pager" Content="失败服务"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding ClearOutputCommand}" Content="清空视图"/>
                </WrapPanel>

                <WrapPanel Visibility="{Binding IsWindowsHost, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="Get-Location" Content="当前目录"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="Get-ChildItem" Content="列表"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="Get-PSDrive -PSProvider FileSystem" Content="磁盘"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="Get-Service | Select-Object -First 20" Content="服务"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding RunQuickCommandCommand}" CommandParameter="Get-Process | Sort-Object CPU -Descending | Select-Object -First 20" Content="进程"/>
                    <Button Style="{StaticResource QuickActionButtonStyle}" Command="{Binding ClearOutputCommand}" Content="清空视图"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="16,14,16,10">
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <materialDesign:PackIcon Kind="Console" Width="16" Height="16" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="会话输出"
                                   Margin="8,0,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding ShortcutHint}"
                               DockPanel.Dock="Right"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <TextBox x:Name="OutputTextBox"
                         Grid.Row="1"
                         Margin="14,0,14,14"
                         IsReadOnly="True"
                         IsUndoEnabled="False"
                         UndoLimit="0"
                         ToolTip="终端视图仅保留最近输出以保证流畅，导出仍包含完整日志。"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="13"
                         Background="Transparent"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         BorderThickness="0"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         SpellCheck.IsEnabled="False"
                         Cursor="IBeam"
                         SelectionBrush="#3B82F6"
                         ContextMenu="{StaticResource TerminalContextMenu}"/>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="0,14,0,0"
                Padding="14"
                Background="{DynamicResource DarkSurfaceBrush}"
                BorderBrush="{DynamicResource DarkBorderBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="36"
                        Height="36"
                        CornerRadius="10"
                        Background="{DynamicResource DarkSurfaceElevatedBrush}"
                        Margin="0,0,10,0">
                    <materialDesign:PackIcon Kind="ChevronRight"
                                             Width="18"
                                             Height="18"
                                             Foreground="{DynamicResource SuccessBrush}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <TextBox x:Name="CommandInput"
                         Grid.Column="1"
                         Text="{Binding CurrentCommand, UpdateSourceTrigger=PropertyChanged}"
                         FontFamily="Cascadia Mono, Consolas"
                         FontSize="13"
                         Background="Transparent"
                         Foreground="{DynamicResource DarkPrimaryTextBrush}"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         materialDesign:HintAssist.Hint="输入命令后按回车..."
                         IsEnabled="{Binding IsExecuting, Converter={StaticResource InverseBoolConverter}}"
                         KeyDown="CommandInput_KeyDown"/>

                <Button Grid.Column="2"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding ExecuteCommandCommand}"
                        IsEnabled="{Binding IsExecuting, Converter={StaticResource InverseBoolConverter}}"
                        Padding="18,8"
                        Margin="10,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Play" Width="16" Height="16"/>
                        <TextBlock Text="执行" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="3"
                        Style="{StaticResource ToolButtonStyle}"
                        Command="{Binding CancelCommandCommand}"
                        IsEnabled="{Binding IsExecuting}"
                        Visibility="{Binding IsExecuting, Converter={StaticResource BoolToVisibilityConverter}}"
                        Padding="16,8"
                        Margin="8,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Stop" Width="16" Height="16"/>
                        <TextBlock Text="中断" Margin="6,0,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11"
                       Foreground="{DynamicResource DarkSecondaryTextBrush}"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <ToggleButton Style="{StaticResource MaterialDesignFlatToggleButton}"
                              IsChecked="{Binding AutoScroll}"
                              Width="28"
                              Height="28"
                              Padding="0"
                              ToolTip="自动滚动">
                    <materialDesign:PackIcon Kind="{Binding AutoScroll, Converter={StaticResource BoolToIconConverter}}"
                                             Width="16"
                                             Height="16"/>
                </ToggleButton>
                <TextBlock Text="自动滚动"
                           Margin="6,0,14,0"
                           FontSize="11"
                           Foreground="{DynamicResource DarkSecondaryTextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding OutputSize}"
                           FontSize="11"
                           Foreground="{DynamicResource DarkSecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
