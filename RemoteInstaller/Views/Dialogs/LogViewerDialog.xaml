<Window x:Class="RemoteInstaller.Views.Dialogs.LogViewerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="日志查看器"
        Height="600" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <materialDesign:PackIcon Kind="FileDocument" Width="24" Height="24" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="应用日志" Style="{StaticResource MaterialDesignHeadline6TextBlock}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 日志路径和信息 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,8">
            <TextBlock x:Name="LogPathText" FontSize="11" Foreground="{DynamicResource MaterialDesignBodyLight}" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button x:Name="RefreshButton" Content="刷新" Style="{StaticResource SecondaryButtonStyle}"
                        Click="RefreshButton_Click" Margin="0,0,8,0" Padding="8,4"/>
                <Button x:Name="OpenFolderButton" Content="打开文件夹" Style="{StaticResource SecondaryButtonStyle}"
                        Click="OpenFolderButton_Click" Margin="0,0,8,0" Padding="8,4"/>
                <Button x:Name="ClearLogsButton" Content="清除日志" Style="{StaticResource SecondaryButtonStyle}"
                        Click="ClearLogsButton_Click" Padding="8,4"/>
            </StackPanel>
        </StackPanel>

        <!-- 日志内容 -->
        <TextBox x:Name="LogTextBox" Grid.Row="2"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="11"
                 Background="{DynamicResource MaterialDesignPaper}"
                 BorderThickness="1"
                 BorderBrush="{DynamicResource MaterialDesignDivider}"/>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="关闭" Style="{StaticResource PrimaryButtonStyle}"
                    Click="CloseButton_Click" Padding="16,8"/>
        </StackPanel>
    </Grid>
</Window>
