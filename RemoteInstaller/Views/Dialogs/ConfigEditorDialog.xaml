<Window
    x:Class="RemoteInstaller.Views.Dialogs.ConfigEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="{Binding Title}"
    Width="860"
    Height="620"
    MinWidth="680"
    MinHeight="460"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    UseLayoutRounding="True"
    TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <Style x:Key="CodeTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="AcceptsTab" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="SpellCheck.IsEnabled" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock
                    Text="{Binding Title}"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource MaterialDesignBody}"/>
                <TextBlock
                    Margin="0,4,0,0"
                    Text="可读取、编辑并保存配置文件，也可按需重启相关服务。"
                    FontSize="12"
                    Foreground="{DynamicResource MaterialDesignBody}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button
                    Margin="8,0,0,0"
                    Style="{StaticResource MaterialDesignToolButton}"
                    ToolTip="保存"
                    Command="{Binding SaveCommand}">
                    <materialDesign:PackIcon Kind="ContentSave" Width="20" Height="20"/>
                </Button>
                <Button
                    Margin="8,0,0,0"
                    Style="{StaticResource MaterialDesignToolButton}"
                    ToolTip="保存并重启"
                    Command="{Binding SaveAndRestartCommand}"
                    Visibility="{Binding SupportsRestart, Converter={StaticResource BoolToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                </Button>
                <Button
                    Margin="8,0,0,0"
                    Style="{StaticResource MaterialDesignToolButton}"
                    ToolTip="关闭"
                    Command="{Binding CancelCommand}">
                    <materialDesign:PackIcon Kind="Close" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <Border
            Grid.Row="1"
            Margin="0,0,0,16"
            Padding="12,10"
            Background="{DynamicResource MaterialDesignCardBackground}"
            CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource MaterialDesignBody}"
                        Kind="FileDocument"/>
                    <TextBlock
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource MaterialDesignBody}"
                        Text="{Binding ConfigFilePath}"/>
                    <materialDesign:PackIcon
                        Grid.Column="2"
                        Width="16"
                        Height="16"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource WarningBrush}"
                        Kind="CircleEditOutline"
                        Visibility="{Binding IsModified, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Grid>

                <Grid
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    Visibility="{Binding SupportsFileSwitch, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource MaterialDesignBody}"
                        Text="当前文件"/>
                    <ComboBox
                        Grid.Column="1"
                        Margin="12,0,0,0"
                        ItemsSource="{Binding AvailableFiles}"
                        SelectedItem="{Binding SelectedFile, Mode=TwoWay}"
                        DisplayMemberPath="DisplayName"
                        materialDesign:HintAssist.Hint="选择要编辑的 Traefik 配置文件"/>
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Background="{DynamicResource MaterialDesignPaper}"
            BorderBrush="{DynamicResource MaterialDesignDivider}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource MaterialDesignBody}"
                        Text="配置项"/>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button
                            Margin="0,0,8,0"
                            Padding="12,4"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding SwitchToStructuredModeCommand}"
                            IsEnabled="{Binding CanSwitchToStructuredMode}"
                            Visibility="{Binding SupportsStructuredEditing, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="结构化模式"/>
                        </Button>
                        <Button
                            Margin="0,0,8,0"
                            Padding="12,4"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding SwitchToTextModeCommand}"
                            IsEnabled="{Binding CanSwitchToTextMode}">
                            <TextBlock Text="文本模式"/>
                        </Button>
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding ShowStructuredActions, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Button
                                Margin="0,0,8,0"
                                Padding="12,4"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding AddItemCommand}">
                                <TextBlock Text="新增项"/>
                            </Button>
                            <Button
                                Padding="12,4"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding RemoveSelectedItemCommand}">
                                <TextBlock Text="删除选中项"/>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,10,0,0"
                        Padding="12"
                        Background="{DynamicResource MaterialDesignCardBackground}"
                        CornerRadius="6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsElasticsearchJvmOptions}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <StackPanel>
                        <TextBox Text="{Binding MemoryLimit, UpdateSourceTrigger=PropertyChanged}"
                                 materialDesign:HintAssist.Hint="内存限制，例如 2g"/>
                        <CheckBox Margin="0,12,0,0"
                                  Content="高级模式"
                                  IsChecked="{Binding IsElasticsearchMemoryAdvancedMode, Mode=TwoWay}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource WarningBrush}"
                                   Text="{Binding MemoryConfigHint}"/>
                        <Grid Margin="0,12,0,0">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsElasticsearchMemoryAdvancedMode}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding JvmXms, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Xms"/>
                            <TextBox Grid.Column="2"
                                     Text="{Binding JvmXmx, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Xmx"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <DataGrid
                    Grid.Row="2"
                    Margin="0,10,0,0"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    HeadersVisibility="Column"
                    GridLinesVisibility="Horizontal"
                    IsReadOnly="{Binding IsLoading}"
                    ItemsSource="{Binding ConfigItems}"
                    PreviewMouseWheel="Editor_PreviewMouseWheel"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                    <DataGrid.Style>
                        <Style TargetType="DataGrid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowKeyValueEditor}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>
                    <DataGrid.Columns>
                        <DataGridTextColumn
                            Width="2*"
                            Header="Key"
                            Binding="{Binding Key, UpdateSourceTrigger=PropertyChanged}"/>
                        <DataGridTextColumn
                            Width="3*"
                            Header="Value"
                            Binding="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TreeView Grid.Row="2"
                          Margin="0,10,0,0"
                          ItemsSource="{Binding YamlTreeNodes}"
                          SelectedItemChanged="YamlConfigTreeView_SelectedItemChanged"
                          PreviewMouseWheel="Editor_PreviewMouseWheel"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource SurfaceLightBrush}"
                          BorderBrush="{DynamicResource BorderBrush}"
                          BorderThickness="1"
                          Foreground="{DynamicResource PrimaryTextBrush}">
                    <TreeView.Style>
                        <Style TargetType="TreeView">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowYamlEditor}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.Style>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource MaterialDesignTreeViewItem}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="MinHeight" Value="24"/>
                            <Setter Property="Padding" Value="2,0,2,0"/>
                            <Setter Property="Margin" Value="0,1,0,1"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceElevatedBrush}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Grid Margin="0,1" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="{Binding DisplayKey}"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=TreeViewItem}, Path=Foreground}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Children.Count}" Value="0">
                                                    <Setter Property="FontWeight" Value="Normal"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox Grid.Column="1"
                                         Margin="8,0,0,0"
                                         VerticalContentAlignment="Center"
                                         MinHeight="24"
                                         Padding="6,2"
                                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                         IsEnabled="{Binding IsEditable}"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Background="{DynamicResource SurfaceBrush}"
                                         BorderBrush="{DynamicResource BorderBrush}"
                                         CaretBrush="{DynamicResource AccentBrush}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding Children.Count}" Value="0"/>
                                                        <Condition Binding="{Binding IsEditable}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <TextBox Grid.Row="2"
                         Margin="0,10,0,0"
                         PreviewMouseWheel="Editor_PreviewMouseWheel"
                         Text="{Binding ConfigContent, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                        <Style TargetType="TextBox" BasedOn="{StaticResource CodeTextBoxStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowTextEditor}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>

                <TextBlock
                    Grid.Row="3"
                    Margin="0,10,0,0"
                    FontSize="12"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    IsHitTestVisible="False"
                    Text="结构化模式支持键值或树形编辑；文本模式可直接编辑原始内容并保存。"/>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon
                    Width="16"
                    Height="16"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    Kind="Information"/>
                <TextBlock
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    Text="{Binding StatusMessage}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Padding="16,6"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}">
                    <TextBlock Text="保存"/>
                </Button>
                <Button
                    Margin="8,0,8,0"
                    Padding="16,6"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding SaveAndRestartCommand}"
                    Visibility="{Binding SupportsRestart, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="保存并重启"/>
                </Button>
                <Button
                    Padding="16,6"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding CancelCommand}">
                    <TextBlock Text="关闭"/>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
