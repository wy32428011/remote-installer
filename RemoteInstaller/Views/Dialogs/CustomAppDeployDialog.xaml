<Window
    x:Class="RemoteInstaller.Views.Dialogs.CustomAppDeployDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="{Binding WindowTitle}"
    Width="980"
    Height="760"
    MinWidth="860"
    MinHeight="640"
    WindowStartupLocation="CenterOwner"
    ResizeMode="CanResize"
    Background="{DynamicResource BackgroundBrush}">

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="18"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerRadiusLarge}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock
                        Text="{Binding WindowTitle}"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock
                        Margin="0,6,0,0"
                        Text="支持上传单个文件或整个文件夹到目标服务器。"
                        FontSize="12"
                        Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Padding="10,6"
                    Background="{DynamicResource AccentBrush}"
                    CornerRadius="{StaticResource CornerRadiusSmall}"
                    VerticalAlignment="Center">
                    <TextBlock
                        Text="{Binding HostDisplay}"
                        Foreground="White"
                        FontWeight="Medium"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Margin="0,0,10,0"
                Padding="16"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusLarge}">
                <StackPanel>
                    <TextBlock
                        Text="本地来源"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock
                        Margin="0,4,0,14"
                        Text="可选择文件，也可直接选择整个文件夹上传。"
                        FontSize="11"
                        Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <TextBlock Text="应用名称" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox
                        Margin="0,6,0,12"
                        Text="{Binding ApplicationName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="本地文件或文件夹" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox
                            x:Name="LocalSourceTextBox"
                            Grid.Column="0"
                            Text="{Binding LocalSourcePath, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button
                            Grid.Column="1"
                            Margin="8,0,0,0"
                            Padding="14,6"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseFileCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileOutline" Width="16" Height="16"/>
                                <TextBlock Margin="6,0,0,0" Text="选文件"/>
                            </StackPanel>
                        </Button>
                        <Button
                            Grid.Column="2"
                            Margin="8,0,0,0"
                            Padding="14,6"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseFolderCommand}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Folder" Width="16" Height="16"/>
                                <TextBlock Margin="6,0,0,0" Text="选文件夹"/>
                            </StackPanel>
                        </Button>
                    </Grid>

                    <Border
                        Margin="0,12,0,0"
                        Padding="12,10"
                        Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="{StaticResource CornerRadiusMedium}">
                        <StackPanel>
                            <TextBlock
                                Text="来源信息"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock
                                Margin="0,4,0,0"
                                Text="{Binding SourceSummary}"
                                TextWrapping="Wrap"
                                Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Border>

                    <CheckBox
                        Margin="0,14,0,0"
                        IsChecked="{Binding PreserveTopLevelDirectory}"
                        Content="上传文件夹时保留顶层目录名"/>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Margin="10,0,0,0"
                Padding="16"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusLarge}">
                <StackPanel>
                    <TextBlock
                        Text="远程目标"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock
                        Margin="0,4,0,14"
                        Text="{Binding RemoteDirectoryHint}"
                        FontSize="11"
                        Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <TextBlock Text="远程目录" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox
                        Margin="0,6,0,12"
                        Text="{Binding RemoteDirectory, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="启动命令" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox
                        Margin="0,6,0,12"
                        Text="{Binding StartCommand, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="配置文件路径" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox
                        Margin="0,6,0,0"
                        Text="{Binding ConfigFilePath, UpdateSourceTrigger=PropertyChanged}"/>

                    <Border
                        Margin="0,12,0,0"
                        Padding="12,10"
                        Background="{DynamicResource SurfaceLightBrush}"
                        CornerRadius="{StaticResource CornerRadiusMedium}">
                        <StackPanel>
                            <TextBlock
                                Text="最终上传路径"
                                FontSize="11"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <TextBlock
                                Margin="0,4,0,0"
                                Text="{Binding RemoteTargetPreview}"
                                TextWrapping="Wrap"
                                Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <Border
            Grid.Row="2"
            Margin="0,16,0,0"
            Padding="16"
            Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource CornerRadiusLarge}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <WrapPanel Grid.Row="0">
                    <Button
                        Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding UploadOnlyCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Upload" Width="16" Height="16"/>
                            <TextBlock Margin="6,0,0,0" Text="仅上传"/>
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding UploadAndStartCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Upload" Width="16" Height="16"/>
                            <TextBlock Margin="6,0,0,0" Text="上传并启动"/>
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding StartApplicationCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Play" Width="16" Height="16"/>
                            <TextBlock Margin="6,0,0,0" Text="执行启动命令"/>
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding EditConfigCommand}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileEditOutline" Width="16" Height="16"/>
                            <TextBlock Margin="6,0,0,0" Text="编辑配置"/>
                        </StackPanel>
                    </Button>

                    <Button
                        Margin="0,0,8,8"
                        Padding="16,8"
                        Style="{StaticResource ToolButtonStyle}"
                        Command="{Binding CancelOperationCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Stop" Width="16" Height="16"/>
                            <TextBlock Margin="6,0,0,0" Text="取消当前任务"/>
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <StackPanel Grid.Row="1" Margin="0,4,0,12">
                    <TextBlock
                        Text="{Binding StatusMessage}"
                        FontSize="12"
                        Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <ProgressBar
                        Margin="0,8,0,0"
                        Height="8"
                        Minimum="0"
                        Maximum="100"
                        Value="{Binding UploadProgress}"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Text="活动日志"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource PrimaryTextBrush}"/>

                    <TextBox
                        Grid.Row="1"
                        Margin="0,10,0,0"
                        Text="{Binding ActivityLog}"
                        IsReadOnly="True"
                        AcceptsReturn="True"
                        TextWrapping="Wrap"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        FontFamily="Cascadia Mono, Consolas"
                        FontSize="12.5"
                        Background="{DynamicResource SurfaceLightBrush}"
                        BorderThickness="0"
                        Padding="12"/>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                Text="提示：可上传目录，目录内会按原有结构递归上传。"
                Foreground="{DynamicResource SecondaryTextBrush}"/>

            <Button
                Grid.Column="1"
                Padding="16,8"
                Style="{StaticResource SecondaryButtonStyle}"
                Command="{Binding CloseCommand}">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                    <TextBlock Margin="6,0,0,0" Text="关闭"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
