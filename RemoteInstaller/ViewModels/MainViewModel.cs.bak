            { Id = "mysql", Name = "MySQL", Version = "8.0.35", Description = "开源关系型数据库", Icon = "🐬", IsSupported = true, OsType = "Linux/Windows" });
            Applications.Add(new ApplicationCardViewModel(this)
            { Id = "redis", Name = "Redis", Version = "7.2.3", Description = "高性能键值数据库", Icon = "📦", IsInstalled = true, IsSupported = true, OsType = "Linux/Windows" });
            Applications.Add(new ApplicationCardViewModel(this)
            { Id = "nginx", Name = "Nginx", Version = "1.24.0", Description = "高性能 Web 服务器", Icon = "🌐", IsSupported = true, OsType = "Linux" });
            Applications.Add(new ApplicationCardViewModel(this)
            { Id = "elasticsearch", Name = "Elasticsearch", Version = "8.14.0", Description = "分布式搜索引擎", Icon = "🔍", IsSupported = true, OsType = "Linux" });
            Applications.Add(new ApplicationCardViewModel(this)
            { Id = "rabbitmq", Name = "RabbitMQ", Version = "3.12.0", Description = "消息队列中间件", Icon = "🐰", IsSupported = true, OsType = "Linux" });
            Applications.Add(new ApplicationCardViewModel(this)
            { Id = "nacos", Name = "Nacos", Version = "2.3.0", Description = "服务发现与配置中心", Icon = "🐱", IsSupported = true, OsType = "Linux" });

            AddLog("系统启动成功", LogLevel.Success);
            AddLog("连接到应用市场...", LogLevel.Info);
            AddLog("加载 6 个应用", LogLevel.Info);
            AddLog("就绪", LogLevel.Success);
        }

        /// <summary>
        /// 添加日志
        /// </summary>
        private void AddLog(string message, LogLevel level)
        {
            Logs.Add(new LogViewModel { Message = message, Level = level });
            if (Logs.Count > 100)
            {
                Logs.RemoveAt(0);
            }
        }

        /// <summary>
        /// 检测所有应用状态
        /// </summary>
        private async Task CheckAllAppsStatusAsync(HostViewModel host)
        {
            try
            {
                AddLog($"开始检测 {host.Name} 上的应用状态...", LogLevel.Info);
                await Task.Delay(100); // 模拟延迟
                AddLog($"应用状态检测功能待完善", LogLevel.Warning);
            }
            catch (Exception ex)
            {
                AddLog($"检测失败：{ex.Message}", LogLevel.Error);
            }
        }

        /// <summary>
        /// 安装应用到指定主机
        /// </summary>
        private async Task InstallApplicationToHost(ApplicationCardViewModel app, HostViewModel host)
        {
            try
            {
                AddLog($"开始安装 {app.Name} 到 {host.Name}...", LogLevel.Info);
                await Task.Delay(1000); // 模拟安装时间
                AddLog($"成功安装 {app.Name} 到 {host.Name}", LogLevel.Success);
            }
            catch (Exception ex)
            {
                AddLog($"安装 {app.Name} 到 {host.Name} 失败：{ex.Message}", LogLevel.Error);
            }
        }

        /// <summary>
        /// 从指定主机卸载应用
        /// </summary>
        private async Task UninstallApplicationFromHost(HostViewModel host)
        {
            try
            {
                AddLog($"开始从 {host.Name} 卸载应用...", LogLevel.Info);
                await Task.Delay(500); // 模拟卸载时间
                AddLog($"成功从 {host.Name} 卸载应用", LogLevel.Success);
            }
            catch (Exception ex)
            {
                AddLog($"从 {host.Name} 卸载应用失败：{ex.Message}", LogLevel.Error);
            }
        }

        // 安装方法补丁 - 替换原有的 InstallApplication 和辅助方法

        /// <summary>
        /// 安装应用 (单个)
        /// </summary>
        [RelayCommand(CanExecute = nameof(CanInstallApplication))]
        private async Task InstallApplication(ApplicationCardViewModel app)
        {
            if (SelectedHost == null)
            {
                MessageBox.Show("请先选择要安装的目标服务器", "提示", MessageBoxButton.OK, MessageBoxImage.Warning);
                return;
            }

            try
            {
                // 1. 选择安装方式
                AddLog("请选择安装方式...", LogLevel.Info);
                var installMode = ShowInstallModeDialog(app.Name);
                
                if (installMode == InstallMode.None)
                {
                    AddLog("用户取消了安装", LogLevel.Warning);
                    return;
                }

                string? localPackagePath = null;
                string version = app.Version;

                if (installMode == InstallMode.Local)
                {
                    // 2a. 本地安装 - 选择本地安装包
                    AddLog("选择本地安装包模式", LogLevel.Info);
                    localPackagePath = ShowPackageFileDialog(app.Name);
                    
                    if (string.IsNullOrEmpty(localPackagePath))
                    {
                        AddLog("用户取消了文件选择", LogLevel.Warning);
                        MessageBox.Show("未选择安装包，安装已取消", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
                        return;
                    }

                    AddLog($"已选择安装包：{Path.GetFileName(localPackagePath)}", LogLevel.Info);

                    // 从安装包文件名提取版本号
                    version = ExtractVersionFromFileName(localPackagePath, app.Version);
                    AddLog($"从文件名检测到版本：{version}", LogLevel.Info);
                }
                else if (installMode == InstallMode.Network)
                {
                    // 2b. 网络安装 - 选择版本号
                    AddLog("网络安装模式", LogLevel.Info);
                    version = ShowVersionSelectDialog(app.Name, app.Version);
                    
                    if (string.IsNullOrEmpty(version))
                    {
                        AddLog("用户取消了版本选择", LogLevel.Warning);
                        MessageBox.Show("未选择版本号，安装已取消", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
                        return;
                    }

                    AddLog($"选择安装版本：{version}", LogLevel.Info);
                }

                // 3. 获取主机信息
                var host = GetHostFromViewModel(SelectedHost);
                if (host == null)
                {
                    AddLog($"无法找到服务器：{SelectedHost.Name}", LogLevel.Error);
                    MessageBox.Show("无法找到目标服务器，请检查服务器列表", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
                    return;
                }

                // 4. 获取应用信息
                var appInfo = GetApplicationInfo(app.Id);
                if (appInfo == null)
                {
                    AddLog($"无法找到应用：{app.Name}", LogLevel.Error);
                    MessageBox.Show("无法找到应用信息", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
                    return;
                }

                // 设置本地包路径和版本
                appInfo.LocalPackagePath = localPackagePath;
                appInfo.UseLocalPackage = !string.IsNullOrEmpty(localPackagePath);
                appInfo.Version = version;

                // 5. 创建安装服务
                var installerService = new InstallerService(_sshService, _logger);

                // 6. 创建 CancellationTokenSource 支持取消操作
                var cts = new CancellationTokenSource();

                // 7. 执行安装
                AddLog($"开始安装 {app.Name} v{version} 到 {SelectedHost.Name}...", LogLevel.Info);
                var task = await installerService.InstallAsync(
                    host,
                    appInfo,
                    new Dictionary<string, string>(),
                    localPackagePath,
                    cts.Token);

                // 8. 更新应用状态
                if (task.Status == Models.TaskStatus.Completed)
                {
                    app.IsInstalled = true;
                    app.IsRunning = true;
                    app.InstalledVersion = version;
                    AddLog($"✅ 安装成功：{app.Name} v{version}", LogLevel.Success);
                    MessageBox.Show($"安装成功！{app.Name} v{version} 已安装到 {SelectedHost.Name}", "成功", MessageBoxButton.OK, MessageBoxImage.Information);
                }
                else if (task.Status == Models.TaskStatus.Failed)
                {
                    AddLog($"❌ 安装失败：{task.ErrorMessage}", LogLevel.Error);
                    MessageBox.Show($"安装失败：{task.ErrorMessage}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
                }
                else
                {
                    AddLog($"安装任务状态：{task.Status}", LogLevel.Warning);
                }
            }
            catch (OperationCanceledException)
            {
                AddLog($"安装已取消", LogLevel.Warning);
                MessageBox.Show("安装已取消", "提示", MessageBoxButton.OK, MessageBoxImage.Information);
            }
            catch (Exception ex)
            {
                AddLog($"安装异常：{ex.Message}", LogLevel.Error);
                MessageBox.Show($"安装失败：{ex.Message}", "错误", MessageBoxButton.OK, MessageBoxImage.Error);
            }
        }

        private bool CanInstallApplication(ApplicationCardViewModel app) => SelectedHost != null && !app.IsInstalled;

        private enum InstallMode { None, Network, Local }

        private InstallMode ShowInstallModeDialog(string appName)
        {
            var window = new Window
            {
                Title = $"安装 {appName}",
                Width = 400, Height = 200,
                WindowStartupLocation = WindowStartupLocation.CenterOwner,
                ResizeMode = ResizeMode.NoResize,
                Content = new Grid
                {
                    Margin = new Thickness(20),
                    RowDefinitions = { new RowDefinition { Height = GridLength.Auto }, new RowDefinition { Height = GridLength.Auto }, new RowDefinition { Height = GridLength.Auto }, new RowDefinition { Height = GridLength.Auto } }
                }
            };

            ((Grid)window.Content).Children.Add(new TextBlock { Text = "请选择安装方式：", FontSize = 14, FontWeight = FontWeight.Bold, Margin = new Thickness(0, 0, 0, 15) });
            
            var networkBtn = new Button { Content = "🌐 网络安装（从仓库下载）", Height = 40, Margin = new Thickness(0, 0, 0, 10), FontSize = 13 };
            networkBtn.Click += (s, e) => { window.DialogResult = true; window.Close(); };
            Grid.SetRow(networkBtn, 1);
            ((Grid)window.Content).Children.Add(networkBtn);

            var localBtn = new Button { Content = "📁 本地安装（选择安装包）", Height = 40, FontSize = 13 };
            localBtn.Click += (s, e) => { window.DialogResult = false; window.Close(); };
            Grid.SetRow(localBtn, 2);
            ((Grid)window.Content).Children.Add(localBtn);

            var cancelBtn = new Button { Content = "取消", Height = 30, Margin = new Thickness(0, 10, 0, 0), Style = (Style)FindResource("MaterialDesignFlatButton") };
            cancelBtn.Click += (s, e) => { window.DialogResult = null; window.Close(); };
            Grid.SetRow(cancelBtn, 3);
            ((Grid)window.Content).Children.Add(cancelBtn);

            var result = window.ShowDialog();
            return result.HasValue ? (result.Value ? InstallMode.Network : InstallMode.Local) : InstallMode.None;
        }

        private string? ShowVersionSelectDialog(string appName, string defaultVersion)
        {
            var window = new Window
            {
                Title = $"选择 {appName} 版本",
                Width = 400, Height = 250,
                WindowStartupLocation = WindowStartupLocation.CenterOwner,
                Content = new Grid
                {
                    Margin = new Thickness(20),
                    RowDefinitions = { new RowDefinition { Height = GridLength.Auto }, new RowDefinition { Height = GridLength.Star }, new RowDefinition { Height = GridLength.Auto } },
                    ColumnDefinitions = { new ColumnDefinition { Width = GridLength.Auto }, new ColumnDefinition { Width = GridLength.Star } }
                }
            };

            ((Grid)window.Content).Children.Add(new TextBlock { Text = "请选择要安装的版本号：", FontSize = 14, FontWeight = FontWeight.Bold, Margin = new Thickness(0, 0, 0, 10) });
            
            var label = new TextBlock { Text = "版本号:", VerticalAlignment = VerticalAlignment.Center, Margin = new Thickness(0, 0, 10, 0) };
            Grid.SetRow(label, 1);
            ((Grid)window.Content).Children.Add(label);

            var versionBox = new TextBox { Text = defaultVersion, FontSize = 14 };
            Grid.SetRow(versionBox, 1); Grid.SetColumn(versionBox, 1);
            ((Grid)window.Content).Children.Add(versionBox);

            var btnPanel = new StackPanel { Orientation = Orientation.Horizontal, HorizontalAlignment = HorizontalAlignment.Right, Margin = new Thickness(0, 15, 0, 0) };
            Grid.SetRow(btnPanel, 2);
            
            var okBtn = new Button { Content = "确定", Width = 80, Height = 30, Margin = new Thickness(0, 0, 10, 0) };
            okBtn.Click += (s, e) => { window.DialogResult = true; window.Close(); };
            btnPanel.Children.Add(okBtn);

            var cancelBtn = new Button { Content = "取消", Width = 80, Height = 30, Style = (Style)FindResource("MaterialDesignFlatButton") };
            cancelBtn.Click += (s, e) => { window.DialogResult = null; window.Close(); };
            btnPanel.Children.Add(cancelBtn);
            
            ((Grid)window.Content).Children.Add(btnPanel);

            var result = window.ShowDialog();
            return result == true ? versionBox.Text : null;
        }

        private string? ShowPackageFileDialog(string appName)
        {
            var dialog = new Microsoft.Win32.OpenFileDialog
            {
                Title = $"选择 {appName} 安装包",
                Filter = "所有安装包|*.zip;*.tar.gz;*.tgz;*.rpm;*.deb;*.msi;*.exe|压缩文件|*.zip;*.tar.gz;*.tgz|RPM 包|*.rpm|DEB 包|*.deb|MSI 包|*.msi|可执行文件|*.exe|所有文件|*.*",
                FilterIndex = 1,
                Multiselect = false
            };
            var result = dialog.ShowDialog();
            return result == true ? dialog.FileName : null;
        }

        private string ExtractVersionFromFileName(string filePath, string defaultVersion)
        {
            var fileName = Path.GetFileNameWithoutExtension(filePath).ToLower();
            var versionMatch = System.Text.RegularExpressions.Regex.Match(fileName, @"(\d+\.\d+\.\d+(?:\.\d+)?)");
            return versionMatch.Success ? versionMatch.Value : defaultVersion;
        }
#region 辅助方法

        /// <summary>
        /// 从 ViewModel 获取 Host 对象
        /// </summary>
        private RemoteHost? GetHostFromViewModel(HostViewModel viewModel)
        {
            // 从数据库获取所有主机
            var allHosts = _databaseService.GetAllHosts();
            
            // 根据名称和 IP 查找匹配的主机
            return allHosts.FirstOrDefault(h => 
                h.Name == viewModel.Name && 
                h.IpAddress == viewModel.IpAddress);
        }

        /// <summary>
        /// 获取应用信息
        /// </summary>
        private ApplicationInfo? GetApplicationInfo(string appId)
        {
            // 根据 appId 返回对应的 ApplicationInfo
            // TODO: 从配置或数据库中加载
            return appId.ToLower() switch
            {
                "mysql" => new ApplicationInfo
                {
                    Id = "mysql",
                    Name = "MySQL",
                    Version = "8.0.35",
                    Description = "开源关系型数据库",
                    Category = "数据库",
                    SupportWindows = true,
                    SupportCentOS = true,
                    SupportUbuntu = true
                },
                "redis" => new ApplicationInfo
                {
                    Id = "redis",
                    Name = "Redis",
                    Version = "7.2.3",
                    Description = "高性能键值数据库",
                    Category = "数据库",
                    SupportWindows = true,
                    SupportCentOS = true,
                    SupportUbuntu = true
                },
                "nginx" => new ApplicationInfo
                {
                    Id = "nginx",
                    Name = "Nginx",
                    Version = "1.24.0",
                    Description = "高性能 Web 服务器",
                    Category = "Web 服务",
                    SupportWindows = false,
                    SupportCentOS = true,
                    SupportUbuntu = true
                },
                "elasticsearch" => new ApplicationInfo
                {
                    Id = "elasticsearch",
                    Name = "Elasticsearch",
                    Version = "8.14.0",
                    Description = "分布式搜索引擎",
                    Category = "搜索",
                    SupportWindows = false,
                    SupportCentOS = true,
                    SupportUbuntu = true
                },
                "rabbitmq" => new ApplicationInfo
                {
                    Id = "rabbitmq",
                    Name = "RabbitMQ",
                    Version = "3.12.0",
                    Description = "消息队列中间件",
                    Category = "中间件",
                    SupportWindows = false,
                    SupportCentOS = true,
                    SupportUbuntu = true
                },
                "nacos" => new ApplicationInfo
                {
                    Id = "nacos",
                    Name = "Nacos",
                    Version = "2.3.0",
                    Description = "服务发现与配置中心",
                    Category = "中间件",
                    SupportWindows = false,
                    SupportCentOS = true,
                    SupportUbuntu = true
                },
                _ => null
            };
        }

        #endregion
    }

    #region 子 ViewModel

    /// <summary>
    /// 主机 ViewModel
    /// </summary>
    public partial class HostViewModel : ObservableObject
    {
        [ObservableProperty]
        private string _name = string.Empty;

        [ObservableProperty]
        private string _ipAddress = string.Empty;

        [ObservableProperty]
        private string _port = "22";

        [ObservableProperty]
        private string _username = string.Empty;

        [ObservableProperty]
        private string _osType = string.Empty;

        [ObservableProperty]
        private string _groupName = string.Empty;

        [ObservableProperty]
        private bool _isOnline;

        public string OsIcon => OsType switch
        {
            "Linux" => "🐧",
            "Windows" => "🪟",
            _ => "🖥️"
        };

        public string StatusColor => IsOnline ? "#00c853" : "#e53935";
    }

    /// <summary>
    /// 任务 ViewModel
    /// </summary>
    public partial class TaskViewModel : ObservableObject
    {
        [ObservableProperty]
        private string _applicationName = string.Empty;

        [ObservableProperty]
        private string _hostName = string.Empty;

        [ObservableProperty]
        private double _progress;

        [ObservableProperty]
        private string _currentStage = string.Empty;

        public string StageDisplayText => CurrentStage;
        public string AppName => ApplicationName;
    }

    /// <summary>
    /// 日志 ViewModel
    /// </summary>
    public partial class LogViewModel : ObservableObject
    {
        [ObservableProperty]
        private string _message = string.Empty;

        [ObservableProperty]
        private LogLevel _level;

        public string DisplayText => $"[{DateTime.Now:HH:mm:ss}] [{GetLevelText()}] {Message}";

        private string GetLevelText() => Level switch
        {
            LogLevel.Info => "INFO",
            LogLevel.Success => "SUCCESS",
            LogLevel.Warning => "WARNING",
            LogLevel.Error => "ERROR",
            _ => "INFO"
        };

        public string LogText => $"[{Level}] {Message}";

        public string LogColor => Level switch
        {
            LogLevel.Info => "#4fc1ff",
            LogLevel.Success => "#4ec9b0",
            LogLevel.Warning => "#dcdcaa",
            LogLevel.Error => "#f14c4c",
            _ => "#d4d4d4"
        };
    }

    #endregion
}

