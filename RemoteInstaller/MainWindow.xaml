<Window x:Class="RemoteInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:RemoteInstaller.ViewModels"
        xmlns:local="clr-namespace:RemoteInstaller.Views.Controls"
        Title="中鼎智能-软件研发-Remote Installer Console"
        Height="720" Width="1180" MinHeight="500" MinWidth="820"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        Background="{DynamicResource BackgroundBrush}">

    <Window.Resources>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题和指标区域 -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusXLarge}"
                Padding="14,10"
                Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0">
                    <TextBlock Text="Remote Installer Console"
                               Style="{StaticResource PageTitleTextStyle}"/>
                    <TextBlock Text="Manage server status, app delivery, and task execution in one view."
                               Style="{StaticResource PageSubtitleTextStyle}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <WrapPanel Grid.Row="0"
                           Grid.Column="2"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top">
                    <Border Style="{StaticResource MetricTileStyle}" Margin="0,0,8,0" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="Online Hosts" Style="{StaticResource SectionSubtitleTextStyle}"/>
                            <TextBlock Text="{Binding ConnectedCount}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricTileStyle}" Padding="10,8">
                        <StackPanel>
                            <TextBlock Text="Tasks" Style="{StaticResource SectionSubtitleTextStyle}"/>
                            <TextBlock Text="{Binding TaskCount}"
                                       Style="{StaticResource MetricValueTextStyle}"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- 主要操作按钮区域 -->
                <WrapPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="0,6,0,0">
                    <Button Content="&#x6DFB;&#x52A0;&#x670D;&#x52A1;&#x5668;"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding AddHostCommand}"
                            Margin="0,0,6,4"
                            Padding="8,4"/>
                    <Button Content="&#x6279;&#x91CF;&#x68C0;&#x6D4B;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BatchCheckStatusCommand}"
                            IsEnabled="{Binding AreServersSelected}"
                            Margin="0,0,6,4"
                            Padding="8,4"/>
                    <Button Content="&#x6279;&#x91CF;&#x5B89;&#x88C5;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BatchInstallCommand}"
                            IsEnabled="{Binding CanRunBatchInstallAction}"
                            Margin="0,0,6,4"
                            Padding="8,4"/>
                    <Button Content="&#x6279;&#x91CF;&#x5378;&#x8F7D;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BatchUninstallCommand}"
                            IsEnabled="{Binding CanRunBatchUninstallAction}"
                            Margin="0,0,6,4"
                            Padding="8,4"/>
                    <Button Content="&#x7EC8;&#x7AEF;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenTerminalCommand}"
                            IsEnabled="{Binding IsServerSelected}"
                            Margin="0,0,6,4"
                            Padding="8,5"/>
                    <Button Content="&#x81EA;&#x5B9A;&#x4E49;&#x5E94;&#x7528;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenCustomAppDeployCommand}"
                            IsEnabled="{Binding IsServerSelected}"
                            Margin="0,0,6,4"
                            Padding="8,5"/>
                    <Button Content="JDK &#x4E0A;&#x4F20;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenJdkUploadCommand}"
                            IsEnabled="{Binding IsServerSelected}"
                            Margin="0,0,6,4"
                            Padding="8,5"/>
                    <Button Content="&#x5386;&#x53F2;&#x8BB0;&#x5F55;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ViewHistoryCommand}"
                            Margin="0,0,6,4"
                            Padding="8,5"/>
                    <Button Content="&#x8BBE;&#x7F6E;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding SettingsCommand}"
                            Margin="0,0,6,4"
                            Padding="8,5"/>
                    <Button Content="&#x65E5;&#x5FD7;"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding OpenLogViewerCommand}"
                            Margin="0,0,6,4"
                            Padding="8,5"/>
                    <Button Style="{StaticResource ToolButtonStyle}"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip="Toggle theme"
                            Width="32"
                            Height="32"
                            Margin="0,0,0,4">
                        <materialDesign:PackIcon Kind="ThemeLightDark"
                                                 Width="18"
                                                 Height="18"/>
                    </Button>
                </WrapPanel>

                <!-- 选中服务器数量提示 -->
                <Border Grid.Row="0"
                        Grid.Column="1"
                        Style="{StaticResource StatusChipStyle}"
                        Margin="16,0,16,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Visibility="{Binding HasSelectedServers, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="{Binding SelectedServersCountDisplay}"
                               Style="{StaticResource StatusChipTextStyle}"/>
                </Border>
            </Grid>
        </Border>

        <!-- 主内容区域：左侧服务器列表，右侧应用和任务 -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="252" MinWidth="200"/> <!-- 左侧服务器列表区域 -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧服务器列表面板 -->
            <Border Grid.Column="0"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CornerRadiusLarge}"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 服务器列表标题 -->
                    <Border Grid.Row="0"
                            Background="{DynamicResource SurfaceLightBrush}"
                            CornerRadius="{StaticResource CornerRadiusLarge}"
                            Padding="12,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Stretch">
                            <TextBlock Text="&#x670D;&#x52A1;&#x5668;&#x5217;&#x8868;"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="{StaticResource CornerRadiusSmall}"
                                    Padding="6,2"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="{Binding FilteredHosts.Count}"
                                           Foreground="White"
                                           FontSize="10"
                                           FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- 搜索框 -->
                    <Border Grid.Row="1" Margin="10,10,10,4">
                        <Border Background="{DynamicResource SurfaceLightBrush}"
                                CornerRadius="{StaticResource CornerRadiusMedium}"
                                Padding="6">
                            <Grid>
                                <materialDesign:PackIcon Kind="Magnify"
                                                         Width="13" Height="13"
                                                         Foreground="{DynamicResource SecondaryTextBrush}"
                                                         VerticalAlignment="Center"
                                                         Margin="3"/>
                                <TextBox materialDesign:HintAssist.Hint="搜索主机、应用..."
                                         VerticalContentAlignment="Center"
                                         Padding="26,2,10,2"
                                         FontSize="11"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Text="{Binding ServerSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            </Grid>
                        </Border>
                    </Border>

                    <!-- 分组筛选下拉框 -->
                    <Border Grid.Row="2" Margin="10,0,10,10">
                        <ComboBox ItemsSource="{Binding GroupFilters}"
                                  SelectedItem="{Binding SelectedGroup}"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  FontSize="11"/>
                    </Border>

                    <!-- 服务器列表 -->
                    <Border Grid.Row="3"
                            Padding="8">
                        <ListBox x:Name="ServerListBox"
                                 ItemsSource="{Binding FilteredHosts}"
                                 SelectedItem="{Binding SelectedHost}"
                                 SelectionChanged="ServerListBox_SelectionChanged"
                                 SelectionMode="Extended"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.ScrollUnit="Pixel"
                                 VirtualizingPanel.CacheLength="2,2">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource DarkListBoxItemStyle}">
                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Border"
                                                        Padding="12,10"
                                                        Background="{DynamicResource SurfaceLightBrush}"
                                                        CornerRadius="{StaticResource CornerRadiusMedium}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1"
                                                        Effect="{StaticResource CardShadow}"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform x:Name="Scale" ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>
                                                            <VisualState x:Name="MouseOver">
                                                                <Storyboard>
                                                                    <ColorAnimation Duration="0:0:0.2"
                                                                                    Storyboard.TargetName="Border"
                                                                                    Storyboard.TargetProperty="Background.Color"
                                                                                    To="{DynamicResource SurfaceLighterColor}"/>
                                                                    <DoubleAnimation Duration="0:0:0.2"
                                                                                     Storyboard.TargetName="Scale"
                                                                                     Storyboard.TargetProperty="ScaleX"
                                                                                     To="1.02"/>
                                                                    <DoubleAnimation Duration="0:0:0.2"
                                                                                     Storyboard.TargetName="Scale"
                                                                                     Storyboard.TargetProperty="ScaleY"
                                                                                     To="1.02"/>
                                                                </Storyboard>
                                                            </VisualState>
                                                            <VisualState x:Name="Selected">
                                                                <Storyboard>
                                                                    <ColorAnimation Duration="0:0:0.2"
                                                                                    Storyboard.TargetName="Border"
                                                                                    Storyboard.TargetProperty="Background.Color"
                                                                                    To="{DynamicResource AccentLightColor}"/>
                                                                    <ColorAnimation Duration="0:0:0.2"
                                                                                    Storyboard.TargetName="Border"
                                                                                    Storyboard.TargetProperty="BorderBrush.Color"
                                                                                    To="{DynamicResource AccentColor}"/>
                                                                </Storyboard>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                    <ContentPresenter/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Border Width="10" Height="10"
                                                    CornerRadius="5"
                                                    Background="{Binding IsOnline, Converter={StaticResource BoolToColorConverter}}">
                                                <Border.Effect>
                                                    <DropShadowEffect Color="{Binding IsOnline, Converter={StaticResource BoolToColorConverter}}" Opacity="0.6" BlurRadius="8"/>
                                                </Border.Effect>
                                            </Border>
                                            <TextBlock Text="{Binding OsIcon}"
                                                       FontSize="16"
                                                       VerticalAlignment="Center"
                                                       Margin="8,0,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="12,0,0,0">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                                            <TextBlock Text="{Binding IpAddress}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Margin="0,3,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Border Background="{DynamicResource SurfaceBrush}"
                                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                                        Padding="4,2">
                                                    <TextBlock Text="{Binding OsVersion}"
                                                               FontSize="9"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Button Content="&#x7F16;&#x8F91;"
                                                    Style="{StaticResource ToolButtonStyle}"
                                                    ToolTip="&#x7F16;&#x8F91;&#x670D;&#x52A1;&#x5668;"
                                                    Command="{Binding DataContext.EditHostCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="6,4"
                                                    FontSize="10"/>
                                            <Button Content="&#x5220;&#x9664;"
                                                    Style="{StaticResource ToolButtonStyle}"
                                                    ToolTip="&#x5220;&#x9664;&#x670D;&#x52A1;&#x5668;"
                                                    Command="{Binding DataContext.DeleteHostCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                    CommandParameter="{Binding}"
                                                    Padding="6,4"
                                                    FontSize="10"
                                                    Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Grid>
            </Border>

            <!-- 右侧主内容区域 -->
            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="96" MinHeight="72"/> <!-- 底部日志区域高度 -->
                </Grid.RowDefinitions>

                <!-- 选中服务器信息栏 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        Margin="0,0,0,6"
                        Padding="10,6"
                        Visibility="{Binding IsServerSelected, Converter={StaticResource BoolToVisibilityConverter}}"
                        Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding ServerInfoText}"
                                   FontSize="12"
                                   FontWeight="Medium"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding ServerInfoTooltipText}"/>
                        <!-- 刷新状态指示器 -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    Visibility="{Binding IsRefreshingAppStatus, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ProgressBar Style="{StaticResource CircularProgressStyle}"
                                         Width="14"
                                         Height="14"
                                         Margin="0,0,5,0"
                                         IsIndeterminate="{Binding IsRefreshingAppStatus}"/>
                            <TextBlock Text="{Binding RefreshStatusText}"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       VerticalAlignment="Center"
                                       FontSize="10"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="128"
                                       ToolTip="{Binding RefreshStatusText}"/>
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="刷新"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding RefreshCommand}"
                                IsEnabled="{Binding IsRefreshingAppStatus, Converter={StaticResource InverseBoolConverter}}"
                                Margin="10,0,0,0"
                                Padding="8,4"/>
                    </Grid>
                </Border>

                <!-- 中间内容：应用市场和任务列表 -->
                <Grid x:Name="MainContentGrid" Grid.Row="1" Margin="0,0,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition x:Name="MainContentPrimaryRowDefinition" Height="*"/>
                        <RowDefinition x:Name="MainContentSecondaryRowDefinition" Height="0"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="MainContentPrimaryColumnDefinition" Width="*"/> <!-- 左侧应用市场/自定义应用/脚本管理 -->
                        <ColumnDefinition x:Name="MainContentSecondaryColumnDefinition" Width="256"/> <!-- 右侧任务列表 -->
                    </Grid.ColumnDefinitions>

                    <!-- 左侧标签页：应用市场、自定义应用、脚本管理 -->
                    <TabControl x:Name="ApplicationTabsPanel" Grid.Row="0" Grid.Column="0"
                                SelectedIndex="{Binding SelectedAppTabIndex}"
                                Style="{StaticResource MaterialDesignTabControl}">
                        <TabItem Header="应用市场">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CornerRadiusLarge}"
                                    Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="{StaticResource CornerRadiusLarge}"
                                            Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        ToolTip="{Binding SelectedApplicationsDisplay}">
                                                <TextBlock Text="应用市场"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <Border Background="{DynamicResource SuccessBrush}"
                                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                                        Padding="6,2"
                                                        Margin="8,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FilteredApplications.Count}"
                                                               Foreground="White"
                                                               FontSize="10"
                                                               FontWeight="Bold"/>
                                                </Border>
                                                <Border Margin="8,0,0,0"
                                                        Padding="6,2"
                                                        CornerRadius="8"
                                                        Style="{StaticResource StatusChipStyle}"
                                                        Visibility="{Binding HasSelectedApplications, Converter={StaticResource BoolToVisibilityConverter}}">
                                                    <TextBlock Text="已选项"
                                                               Style="{StaticResource StatusChipTextStyle}"/>
                                                </Border>
                                            </StackPanel>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding SelectedApplicationsDisplay}"
                                                       MaxWidth="260"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding SelectedApplicationsDisplay}"
                                                       Visibility="{Binding HasSelectedApplications, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" Margin="8,6,8,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120" MinWidth="108"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Background="{DynamicResource SurfaceLightBrush}"
                                                CornerRadius="{StaticResource CornerRadiusMedium}"
                                                Padding="5"
                                                Margin="0,0,6,0">
                                            <Grid>
                                                <materialDesign:PackIcon Kind="Magnify"
                                                                         Width="14" Height="14"
                                                                         Foreground="{DynamicResource SecondaryTextBrush}"
                                                                         VerticalAlignment="Center"
                                                                         Margin="4"/>
                                                <TextBox materialDesign:HintAssist.Hint="搜索应用..."
                                                         VerticalContentAlignment="Center"
                                                         Padding="28,2,10,2"
                                                         FontSize="11"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                                         Text="{Binding AppSearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                        </Border>

                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding AppCategoryFilters}"
                                                  SelectedItem="{Binding SelectedAppCategory}"
                                                  Style="{StaticResource DarkComboBoxStyle}"
                                                  FontSize="11"
                                                  VerticalContentAlignment="Center"/>
                                    </Grid>

                                    <Grid Grid.Row="2" Margin="8,0,8,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 应用市场列表表头 -->
                                        <Border Grid.Row="0"
                                                Background="{DynamicResource SurfaceElevatedBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource CornerRadiusMedium}"
                                                Padding="12,6"
                                                Margin="0,0,0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="128"/>
                                                    <ColumnDefinition Width="92"/>
                                                    <ColumnDefinition Width="148"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0"
                                                           Text="选择"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="应用信息"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2"
                                                           Text="状态"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="3"
                                                           Text="已装版本"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="4"
                                                           Text="操作"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>

                                        <!-- 应用市场列表主体 -->
                                        <ListBox Grid.Row="1"
                                                 Style="{StaticResource DarkListBoxStyle}"
                                                 ItemsSource="{Binding FilteredApplications}"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                                 VirtualizingPanel.CacheLength="4,4">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                                    <Setter Property="Focusable" Value="False"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <ContentPresenter/>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <!-- 单行应用项：保留原有命令与状态，只调整展示结构 -->
                                                    <Border Background="{DynamicResource SurfaceLightBrush}"
                                                            BorderBrush="{DynamicResource BorderBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="{StaticResource CornerRadiusLarge}"
                                                            Padding="10,6"
                                                            Effect="{StaticResource CardShadow}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                                        <Setter Property="BorderThickness" Value="2"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="44"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="128"/>
                                                                <ColumnDefinition Width="92"/>
                                                                <ColumnDefinition Width="148"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- 选择列：只走命令链，避免绕过批量状态刷新 -->
                                                            <CheckBox Grid.Column="0"
                                                                      Margin="0,0,12,0"
                                                                      VerticalAlignment="Center"
                                                                      IsChecked="{Binding IsSelected, Mode=OneWay}"
                                                                      Command="{Binding SelectCommand}"
                                                                      ToolTip="选择用于批量操作"/>

                                                            <!-- 应用信息列：合并名称、版本、描述、平台，提升主窗口适配性 -->
                                                            <Grid Grid.Column="1" Margin="0,0,12,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <Border Width="32"
                                                                        Height="32"
                                                                        Background="{DynamicResource SunsetGradient}"
                                                                        CornerRadius="9"
                                                                        VerticalAlignment="Top">
                                                                    <TextBlock Text="{Binding Icon}"
                                                                               FontSize="16"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                </Border>

                                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                                    <WrapPanel VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Name}"
                                                                                   FontWeight="SemiBold"
                                                                                   FontSize="13"
                                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding Version, StringFormat=' v{0}'}"
                                                                                   Margin="8,0,0,0"
                                                                                   FontSize="11"
                                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                                   VerticalAlignment="Center">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Id}" Value="jdk">
                                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <TextBlock Text=" 安装时选择版本"
                                                                                   Margin="8,0,0,0"
                                                                                   FontSize="11"
                                                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                                                   VerticalAlignment="Center"
                                                                                   Visibility="Collapsed">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding Id}" Value="jdk">
                                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                        <Border Background="{DynamicResource AccentBrush}"
                                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                                Padding="6,2"
                                                                                Margin="8,0,0,0"
                                                                                VerticalAlignment="Center"
                                                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                            <TextBlock Text="已选中"
                                                                                       Foreground="White"
                                                                                       FontSize="9"
                                                                                       FontWeight="SemiBold"/>
                                                                        </Border>
                                                                        <Border Background="{DynamicResource AppOsTagBackgroundBrush}"
                                                                                CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                                Padding="6,2"
                                                                                Margin="8,0,0,0"
                                                                                VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding OsType}"
                                                                                       FontSize="9"
                                                                                       Foreground="{DynamicResource AppOsTagTextBrush}"
                                                                                       FontWeight="Medium"/>
                                                                        </Border>
                                                                    </WrapPanel>
                                                                    <TextBlock Text="{Binding Description}"
                                                                               Margin="0,2,0,0"
                                                                               FontSize="10"
                                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               ToolTip="{Binding Description}"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- 状态列：合并安装与运行状态，减少横向占用 -->
                                                            <WrapPanel Grid.Column="2"
                                                                       Margin="0,0,10,0"
                                                                       VerticalAlignment="Center">
                                                                <Border Padding="5,2"
                                                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                        Background="{DynamicResource SurfaceBrush}">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <TextBlock Text="未安装"
                                                                               FontSize="9"
                                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                                               FontWeight="Medium"/>
                                                                </Border>
                                                                <Border Padding="5,2"
                                                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                        Background="{DynamicResource AppInstalledTagBackgroundBrush}"
                                                                        Margin="3,0,0,0"
                                                                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <TextBlock Text="已安装"
                                                                               FontSize="9"
                                                                               Foreground="{DynamicResource AppInstalledTagTextBrush}"
                                                                               FontWeight="Medium"/>
                                                                </Border>
                                                                <Border Padding="5,2"
                                                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                                                        Background="{DynamicResource AppRunningTagBackgroundBrush}"
                                                                        Margin="3,0,0,0"
                                                                        Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <TextBlock Text="运行中"
                                                                               FontSize="9"
                                                                               Foreground="{DynamicResource AppRunningTagTextBrush}"
                                                                               FontWeight="Medium"/>
                                                                </Border>
                                                            </WrapPanel>

                                                            <StackPanel Grid.Column="3"
                                                                        Margin="0,0,12,0"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding InstalledVersion}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                                           TextTrimming="CharacterEllipsis"
                                                                           ToolTip="{Binding InstalledVersion}"
                                                                           Visibility="{Binding InstalledVersion, Converter={StaticResource StringToVisibilityConverter}}"/>
                                                                <TextBlock Text="--"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding InstalledVersion, Converter={StaticResource StringToVisibilityConverter}}" Value="Visible">
                                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </StackPanel>

                                                            <!-- 操作列：保留安装主操作，其余动作图标化以减少横向占用 -->
                                                            <StackPanel Grid.Column="4"
                                                                        Orientation="Horizontal"
                                                                        HorizontalAlignment="Right"
                                                                        VerticalAlignment="Center">
                                                                <Button Content="安装"
                                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                                        Command="{Binding InstallCommand}"
                                                                        FontSize="10"
                                                                        MinWidth="52"
                                                                        Padding="8,4"
                                                                        Margin="0,0,4,0"/>
                                                                <Button Style="{StaticResource ToolButtonStyle}"
                                                                        ToolTip="刷新状态"
                                                                        Command="{Binding CheckStatusCommand}"
                                                                        Width="28"
                                                                        Height="28"
                                                                        Padding="0"
                                                                        Margin="0,0,4,0">
                                                                    <materialDesign:PackIcon Kind="Refresh"
                                                                                             Width="14"
                                                                                             Height="14"/>
                                                                </Button>
                                                                <Button Style="{StaticResource ToolButtonStyle}"
                                                                        ToolTip="编辑配置"
                                                                        Command="{Binding ConfigureCommand}"
                                                                        Width="28"
                                                                        Height="28"
                                                                        Padding="0"
                                                                        Margin="0,0,4,0">
                                                                    <TextBlock Text="配"
                                                                               FontSize="10"
                                                                               FontWeight="SemiBold"/>
                                                                </Button>
                                                                <Button Style="{StaticResource ToolButtonStyle}"
                                                                        ToolTip="卸载"
                                                                        Command="{Binding UninstallCommand}"
                                                                        Width="28"
                                                                        Height="28"
                                                                        Padding="0">
                                                                    <materialDesign:PackIcon Kind="Delete"
                                                                                             Width="14"
                                                                                             Height="14"/>
                                                                </Button>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Grid>
                            </Border>
                        </TabItem>
                        <TabItem Header="自定义应用">
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CornerRadiusLarge}"
                                    Effect="{StaticResource CardShadow}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0"
                                            Background="{DynamicResource SurfaceLightBrush}"
                                            CornerRadius="{StaticResource CornerRadiusLarge}"
                                            Padding="12,10"
                                            Margin="10,10,10,0">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="自定义应用"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                    <Border Background="{DynamicResource WarningBrush}"
                                                            CornerRadius="{StaticResource CornerRadiusSmall}"
                                                            Padding="6,2"
                                                            Margin="8,0,0,0"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding CustomApps.Count}"
                                                                   Foreground="White"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"/>
                                                    </Border>
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Content="添加应用"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Command="{Binding AddCustomAppCommand}"
                                                        Padding="10,6"/>
                                            </Grid>
                                            <TextBlock Text="选择服务器后开始部署自定义应用"
                                                       Margin="0,8,0,0"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       FontSize="11"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 未选择服务器时的提示 -->
                                    <StackPanel Grid.Row="1"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Visibility="{Binding IsServerSelected, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}">
                                        <materialDesign:PackIcon Kind="ServerNetworkOff"
                                                                 Width="48" Height="48"
                                                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                                                 HorizontalAlignment="Center"/>
                                        <TextBlock Text="请先选择一台服务器"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,12,0,0"/>
                                    </StackPanel>

                                    <!-- 应用卡片列表 -->
                                    <ScrollViewer Grid.Row="1"
                                                  Style="{DynamicResource ScrollViewerStyle}"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Padding="12,8,12,12"
                                                  Visibility="{Binding IsServerSelected, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl ItemsSource="{Binding CustomApps}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Vertical"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,8"
                                                            Background="{DynamicResource SurfaceLightBrush}"
                                                            CornerRadius="{StaticResource CornerRadiusLarge}"
                                                            Effect="{StaticResource CardShadow}"
                                                            Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick" Command="{Binding DeployCommand}"/>
                                                        </Border.InputBindings>
                                                        <Grid Margin="12,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- 应用图标 -->
                                                            <Border Grid.Column="0"
                                                                    Width="46" Height="46"
                                                                    Background="{DynamicResource SunsetGradient}"
                                                                    CornerRadius="16"
                                                                    VerticalAlignment="Center">
                                                                <Border.Effect>
                                                                    <DropShadowEffect Color="#EC4899" Opacity="0.4" BlurRadius="16" ShadowDepth="3"/>
                                                                </Border.Effect>
                                                                <TextBlock Text="{Binding Icon}"
                                                                           FontSize="23"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>

                                                            <!-- 应用名称和描述 -->
                                                            <StackPanel Grid.Column="1"
                                                                        VerticalAlignment="Center"
                                                                        Margin="12,0">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Name}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="14"
                                                                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                                    <Border Margin="8,0,0,0"
                                                                            Padding="6,2"
                                                                            CornerRadius="8"
                                                                            VerticalAlignment="Center">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="Background" Value="{DynamicResource AppInstalledTagBackgroundBrush}"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding StatusText}" Value="运行中">
                                                                                        <Setter Property="Background" Value="{DynamicResource AppRunningTagBackgroundBrush}"/>
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding StatusText}" Value="检测失败">
                                                                                        <Setter Property="Background" Value="#6B1F1F"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <TextBlock Text="{Binding StatusText}"
                                                                                   FontSize="10"
                                                                                   FontWeight="SemiBold"
                                                                                   Foreground="{DynamicResource AppRunningTagTextBrush}"/>
                                                                    </Border>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Description}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           Margin="0,3,0,0"/>
                                                            </StackPanel>

                                                            <!-- 操作按钮 -->
                                                            <WrapPanel Grid.Column="2"
                                                                       VerticalAlignment="Center"
                                                                       Margin="0,8,0,0">
                                                                <Button Content="编辑"
                                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                                        Command="{Binding DataContext.EditCustomAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Padding="10,6"
                                                                        Margin="0,0,8,6"/>
                                                                <Button Content="删除"
                                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                                        Command="{Binding DataContext.DeleteCustomAppCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Padding="10,6"
                                                                        Margin="0,0,8,6"
                                                                        IsEnabled="{Binding IsBuiltIn, Converter={StaticResource InverseBoolConverter}}"/>
                                                                <Button Content="部署"
                                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                                        Command="{Binding DeployCommand}"
                                                                        Padding="14,6"
                                                                        Margin="0,0,0,6"/>
                                                            </WrapPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </TabItem>

                        <!-- 脚本管理标签页 -->
                        <TabItem Header="脚本管理">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 提示信息 -->
                                <Border Grid.Row="0"
                                        Padding="12,8"
                                        Background="{DynamicResource SurfaceLightBrush}"
                                        CornerRadius="{StaticResource CornerRadiusMedium}"
                                        Margin="0,0,0,12"
                                        Visibility="{Binding ScriptManagementViewModel, Converter={StaticResource NullToVisibilityConverter}}">
                                    <TextBlock Text="请先在左侧选择一台服务器，然后切换到脚本管理标签页"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               FontSize="12"/>
                                </Border>

                                <!-- 脚本管理控件 -->
                                <ContentControl Grid.Row="1"
                                                Content="{Binding ScriptManagementViewModel}"
                                                Visibility="{Binding ScriptManagementViewModel, Converter={StaticResource NotNullToVisibilityConverter}}">
                                    <ContentControl.ContentTemplate>
                                        <DataTemplate DataType="{x:Type vm:ScriptManagementViewModel}">
                                            <local:ScriptManagementControl DataContext="{Binding}"/>
                                        </DataTemplate>
                                    </ContentControl.ContentTemplate>
                                </ContentControl>
                            </Grid>
                        </TabItem>
                    </TabControl>
                    <!-- 右侧任务列表面板 -->
                    <Border x:Name="TaskPanel" Grid.Row="0" Grid.Column="1"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusLarge}"
                            Margin="10,0,0,0"
                            Effect="{StaticResource CardShadow}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0"
                                    Background="{DynamicResource SurfaceLightBrush}"
                                    CornerRadius="{StaticResource CornerRadiusLarge}"
                                    Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Command="{Binding ToggleTaskPanelCommand}"
                                            ToolTip="{Binding TaskPanelToggleTooltip}"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            HorizontalContentAlignment="Stretch"
                                            Cursor="Hand">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <materialDesign:PackIcon Grid.Column="0"
                                                                     Width="18"
                                                                     Height="18"
                                                                     Margin="0"
                                                                     VerticalAlignment="Center"
                                                                     Foreground="{DynamicResource PrimaryTextBrush}">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Kind" Value="ChevronDown"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTaskPanelCollapsed}" Value="True">
                                                                <Setter Property="Kind" Value="ChevronRight"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="&#x4EFB;&#x52A1;&#x5217;&#x8868;"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Visibility="{Binding IsTaskPanelExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <Border Background="{DynamicResource WarningBrush}"
                                                        CornerRadius="{StaticResource CornerRadiusSmall}"
                                                        Padding="6,2"
                                                        Margin="0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FilteredTasks.Count}"
                                                               Foreground="White"
                                                               FontSize="10"
                                                               FontWeight="Bold"/>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Button>

                                    <ComboBox Grid.Column="1"
                                              MinWidth="96"
                                              Margin="12,0,0,0"
                                              ItemsSource="{Binding TaskFilters}"
                                              SelectedItem="{Binding SelectedTaskFilter}"
                                              Style="{StaticResource DarkComboBoxStyle}"
                                              FontSize="11"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding IsTaskPanelExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </Border>

                            <Grid Grid.Row="1"
                                  Visibility="{Binding IsTaskPanelExpanded, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Border Background="{DynamicResource SurfaceLightBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource CornerRadiusMedium}"
                                        Margin="10"
                                        Padding="14,12"
                                        Visibility="{Binding ShowTaskEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="暂无任务"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding TaskEmptyStateText}"
                                                   Margin="0,8,0,0"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>

                                <Border Padding="10"
                                        Visibility="{Binding HasFilteredTasks, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <ListBox ItemsSource="{Binding FilteredTasks}"
                                             SelectedItem="{Binding SelectedTask}"
                                             MouseDoubleClick="TaskListBox_MouseDoubleClick"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             ScrollViewer.CanContentScroll="True"
                                             VirtualizingPanel.IsVirtualizing="True"
                                             VirtualizingPanel.VirtualizationMode="Recycling"
                                             VirtualizingPanel.ScrollUnit="Pixel"
                                             VirtualizingPanel.CacheLength="2,2">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource DarkListBoxItemStyle}">
                                                <Setter Property="Margin" Value="0,0,0,8"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="12,10"
                                                        Background="{DynamicResource SurfaceLightBrush}"
                                                        BorderBrush="{Binding CardBorderBrush, Converter={StaticResource StringToColorConverter}}"
                                                        BorderThickness="{Binding CardBorderThickness}"
                                                        CornerRadius="{StaticResource CornerRadiusMedium}"
                                                        Effect="{StaticResource CardShadow}">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0"
                                                                        Orientation="Vertical">
                                                                <TextBlock Text="{Binding ApplicationName}"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="13"
                                                                           VerticalAlignment="Center"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding HostName}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,2,0,0"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>

                                                            <Border Grid.Column="1"
                                                                    Background="{Binding StatusColor, Converter={StaticResource StringToColorConverter}}"
                                                                    CornerRadius="10"
                                                                    Padding="8,3"
                                                                    Margin="12,0,0,0"
                                                                    VerticalAlignment="Top">
                                                                <TextBlock Text="{Binding StatusBadgeText}"
                                                                           Foreground="White"
                                                                           FontSize="10"
                                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </Grid>

                                                        <Grid Grid.Row="1" Margin="0,10,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0"
                                                                        Orientation="Vertical">
                                                                <TextBlock Text="{Binding StageDisplayText}"
                                                                           FontSize="12"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Text="{Binding SummaryText}"
                                                                           FontSize="10"
                                                                           Margin="0,3,0,0"
                                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                                           TextWrapping="Wrap"
                                                                           MaxWidth="190"/>
                                                            </StackPanel>

                                                            <TextBlock Grid.Column="1"
                                                                       Text="{Binding ProgressText}"
                                                                       FontSize="14"
                                                                       FontWeight="Bold"
                                                                       Margin="12,0,0,0"
                                                                       VerticalAlignment="Top"
                                                                       Foreground="{DynamicResource AccentBrush}"/>
                                                        </Grid>

                                                        <ProgressBar Grid.Row="2"
                                                                     Value="{Binding Progress}"
                                                                     Minimum="0" Maximum="100"
                                                                     Height="6"
                                                                     Margin="0,12,0,0"
                                                                     VerticalAlignment="Center"
                                                                     Background="{DynamicResource SurfaceBrush}"
                                                                     Foreground="{DynamicResource AccentBrush}"/>

                                                        <Grid Grid.Row="3" Margin="0,8,0,0">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <TextBlock Grid.Row="0"
                                                                       Grid.Column="0"
                                                                       Text="{Binding CurrentStage, StringFormat=当前阶段：{0}}"
                                                                       FontSize="10"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Center"/>

                                                            <Button Grid.Row="0"
                                                                    Grid.Column="1"
                                                                    Content="详情"
                                                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                                                    FontSize="10"
                                                                    Padding="8,3"
                                                                    Margin="12,0,0,0"
                                                                    Command="{Binding DataContext.ShowTaskProgressDialogCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                                    CommandParameter="{Binding}"/>

                                                            <TextBlock Grid.Row="1"
                                                                       Grid.Column="0"
                                                                       Grid.ColumnSpan="2"
                                                                       Text="{Binding LastActivityText}"
                                                                       FontSize="9"
                                                                       Margin="0,6,0,0"
                                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                                       TextWrapping="Wrap"/>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <GridSplitter Grid.Row="2"
                              Height="8"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{DynamicResource BorderBrush}"
                              ShowsPreview="True"/>

                <!-- 底部日志面板 -->
                <Border Grid.Row="3"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CornerRadiusLarge}"
                        Effect="{StaticResource CardShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="{DynamicResource SurfaceLightBrush}"
                                CornerRadius="{StaticResource CornerRadiusLarge}"
                                Padding="12,8">
                            <TextBlock Text="&#x64CD;&#x4F5C;&#x65E5;&#x5FD7;"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"/>
                        </Border>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Logs}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="10"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="Focusable" Value="False"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayText}"
                                               FontFamily="Consolas"
                                               FontSize="11"
                                               Margin="0,2"
                                               LineHeight="16">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部状态栏 -->
        <Border Grid.Row="2"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusLarge}"
                Margin="0,12,0,0"
                Padding="10,5"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <WrapPanel>
                    <materialDesign:PackIcon Kind="Monitor"
                                             Width="14"
                                             Height="14"
                                             Foreground="{DynamicResource AccentBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,0,6"/>
                    <TextBlock Text="&#x5DF2;&#x8FDE;&#x63A5;&#xFF1A;"
                               VerticalAlignment="Center"
                               Margin="6,0,0,6"
                               FontSize="12"/>
                    <TextBlock Text="{Binding ConnectedCount}"
                               FontWeight="SemiBold"
                               Margin="4,0,12,6"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="12"/>

                    <materialDesign:PackIcon Kind="ClipboardText"
                                             Width="14"
                                             Height="14"
                                             Foreground="{DynamicResource SuccessBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,0,6"/>
                    <TextBlock Text="&#x4EFB;&#x52A1;&#x6570;&#xFF1A;"
                               VerticalAlignment="Center"
                               Margin="6,0,0,6"
                               FontSize="12"/>
                    <TextBlock Text="{Binding TaskCount}"
                               FontWeight="SemiBold"
                               Margin="4,0,12,6"
                               Foreground="{DynamicResource SuccessBrush}"
                               FontSize="12"/>

                    <materialDesign:PackIcon Kind="Information"
                                             Width="14"
                                             Height="14"
                                             Foreground="{DynamicResource SecondaryTextBrush}"
                                             VerticalAlignment="Center"
                                             Margin="0,0,0,6"/>
                    <TextBlock Text="&#x7248;&#x672C;&#xFF1A;"
                               VerticalAlignment="Center"
                               Margin="6,0,0,6"
                               FontSize="12"/>
                    <TextBlock Text="{Binding CurrentVersionDisplay}"
                               FontWeight="SemiBold"
                               Margin="4,0,12,6"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12"/>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Command="{Binding CheckForUpdatesCommand}"
                            IsEnabled="{Binding CanCheckForUpdates}"
                            Padding="8,3"
                            Margin="0,0,12,6"
                            ToolTip="{Binding UpdateIndicatorText}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Refresh"
                                                     Width="14"
                                                     Height="14"
                                                     VerticalAlignment="Center"/>
                            <TextBlock Text="&#x68C0;&#x6D4B;&#x66F4;&#x65B0;"
                                       Margin="5,0,0,0"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <TextBlock Text="{Binding UpdateIndicatorText}"
                               VerticalAlignment="Center"
                               Margin="0,0,0,6"
                               FontSize="11"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </WrapPanel>

                <WrapPanel Margin="0,2,0,0">
                    <materialDesign:PackIcon Kind="SourceCommit"
                                             Width="14"
                                             Height="14"
                                             Foreground="{DynamicResource WarningBrush}"
                                             VerticalAlignment="Top"
                                             Margin="0,2,0,6"/>
                    <TextBlock Text="&#x4ED3;&#x5E93;&#xFF1A;"
                               VerticalAlignment="Top"
                               Margin="6,0,0,6"
                               FontSize="12"/>
                    <TextBlock Text="{Binding RepositoryUrl}"
                               FontSize="11"
                               Margin="4,0,0,6"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap"/>
                </WrapPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>


