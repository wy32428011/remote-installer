      "id": "mysql",
      "name": "MySQL",
      "category": "数据库",
      "icon": "🐬",
      "description": "流行的开源关系型数据库管理系统",
      "osSupport": ["Linux", "Windows"],
      "versions": [
        {
          "version": "8.0.35",
          "packageUrl": "https://dev.mysql.com/get/Downloads/MySQL-8.0/mysql-8.0.35-winx64.zip",
          "linuxPackageUrl": "https://dev.mysql.com/get/Downloads/MySQL-8.0/mysql-8.0.35-linux-glibc2.28-x86_64.tar.xz",
          "checksum": "",
          "parameters": [
            {
              "name": "Port",
              "type": "Port",
              "default": "3306",
              "required": true,
              "description": "MySQL 服务端口"
            },
            {
              "name": "Root Password",
              "type": "Password",
              "default": "",
              "required": true,
              "description": "root 用户密码"
            },
            {
              "name": "Data Directory",
              "type": "Path",
              "default": "/var/lib/mysql",
              "required": false,
              "description": "数据目录路径"
            }
          ]
        },
        {
          "version": "5.7.44",
          "packageUrl": "https://dev.mysql.com/get/Downloads/MySQL-5.7/mysql-5.7.44-winx64.zip",
          "linuxPackageUrl": "https://dev.mysql.com/get/Downloads/MySQL-5.7/mysql-5.7.44-linux-glibc2.12-x86_64.tar.gz",
          "checksum": "",
          "parameters": [
            {
              "name": "Port",
              "type": "Port",
              "default": "3306",
              "required": true,
              "description": "MySQL 服务端口"
            },
            {
              "name": "Root Password",
              "type": "Password",
              "default": "",
              "required": true,
              "description": "root 用户密码"
            },
            {
              "name": "Data Directory",
              "type": "Path",
              "default": "/var/lib/mysql",
              "required": false,
              "description": "数据目录路径"
            }
          ]
        }
      ],
      "scripts": {
        "install": {
          "linux": "sudo tar -xJf {package} -C /opt && sudo ln -s /opt/mysql-{version} /opt/mysql && sudo mkdir -p /var/lib/mysql && sudo mysqld --initialize-insecure --user=mysql --datadir=/var/lib/mysql && sudo systemctl start mysqld",
          "windows": "cd {extractPath} && .\\mysql-installer.exe"
        },
        "uninstall": {
          "linux": "bash Scripts/MySQL/uninstall_linux.sh",
          "windows": "msiexec /x {package} /qn"
        },
        "detect": {
          "linux": "bash Scripts/MySQL/check_status_linux.sh",
          "windows": "sc query MySQL80 && mysql --version"
        }
      }
    },
