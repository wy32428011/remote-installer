          "packageUrl": "https://nginx.org/download/nginx-1.25.3.zip",
          "linuxPackageUrl": "https://nginx.org/download/nginx-1.25.3.tar.gz",
          "checksum": "",
          "parameters": [
            {
              "name": "HTTP Port",
              "type": "Port",
              "default": "80",
              "required": true,
              "description": "HTTP 端口"
            },
            {
              "name": "HTTPS Port",
              "type": "Port",
              "default": "443",
              "required": true,
              "description": "HTTPS 端口"
            },
            {
              "name": "Worker Processes",
              "type": "Number",
              "default": "auto",
              "required": false,
              "description": "工作进程数"
            }
          ]
        },
        {
          "version": "1.24.0",
          "packageUrl": "https://nginx.org/download/nginx-1.24.0.zip",
          "linuxPackageUrl": "https://nginx.org/download/nginx-1.24.0.tar.gz",
          "checksum": "",
          "parameters": [
            {
              "name": "HTTP Port",
              "type": "Port",
              "default": "80",
              "required": true,
              "description": "HTTP 端口"
            },
            {
              "name": "HTTPS Port",
              "type": "Port",
              "default": "443",
              "required": true,
              "description": "HTTPS 端口"
            },
            {
              "name": "Worker Processes",
              "type": "Number",
              "default": "auto",
              "required": false,
              "description": "工作进程数"
            }
          ]
        }
      ],
      "scripts": {
        "install": {
          "linux": "cd /opt && tar -xzf {package} && cd nginx-{version} && ./configure --prefix=/usr/local/nginx && make && sudo make install && sudo ln -sf /usr/local/nginx/sbin/nginx /usr/sbin/nginx",
          "windows": "powershell -ExecutionPolicy Bypass -File \"Scripts/Nginx/install_windows.ps1\" -PackagePath \"{package}\" -HttpPort {http_port} -HttpsPort {https_port} -InstallPath \"C:\\Program Files\\Nginx\""
        },
        "uninstall": {
          "linux": "sudo nginx -s stop && sudo rm -rf /usr/local/nginx /etc/nginx && sudo rm -f /usr/sbin/nginx",
          "windows": "powershell -ExecutionPolicy Bypass -File \"Scripts/Nginx/uninstall_windows.ps1\" -InstallPath \"C:\\Program Files\\Nginx\""
        },
        "detect": {
          "linux": "systemctl status nginx || nginx -v",
          "windows": "tasklist | findstr nginx && nginx -v"
        }
      }
    },
