          "checksum": "",
          "parameters": [
            {
              "name": "Port",
              "type": "Port",
              "default": "6379",
              "required": true,
              "description": "Redis 服务端口"
            },
            {
              "name": "Max Memory",
              "type": "Text",
              "default": "256mb",
              "required": false,
              "description": "最大内存限制"
            },
            {
              "name": "Password",
              "type": "Password",
              "default": "",
              "required": false,
              "description": "访问密码（可选）"
            }
          ]
        },
        {
          "version": "6.2.13",
          "packageUrl": "https://github.com/microsoftarchive/redis/releases/download/win-3.0.504/Redis-3.0.504.msi",
          "linuxPackageUrl": "https://download.redis.io/releases/redis-6.2.13.tar.gz",
          "checksum": "",
          "parameters": [
            {
              "name": "Port",
              "type": "Port",
              "default": "6379",
              "required": true,
              "description": "Redis 服务端口"
            },
            {
              "name": "Max Memory",
              "type": "Text",
              "default": "256mb",
              "required": false,
              "description": "最大内存限制"
            },
            {
              "name": "Password",
              "type": "Password",
              "default": "",
              "required": false,
              "description": "访问密码（可选）"
            }
          ]
        }
      ],
      "scripts": {
        "install": {
          "linux": "cd /opt && tar -xzf {package} && cd redis-{version} && make && sudo make install && sudo mkdir -p /etc/redis && sudo cp redis.conf /etc/redis/ && sudo systemctl start redis-server",
          "windows": "cd {extractPath} && redis-server.exe --service-install && redis-server.exe --service-start"
        },
        "uninstall": {
          "linux": "sudo systemctl stop redis-server && sudo rm -rf /etc/redis /var/lib/redis && cd /opt/redis-* && sudo make uninstall",
          "windows": "redis-server.exe --service-uninstall"
        },
        "detect": {
          "linux": "systemctl status redis-server && redis-cli --version",
          "windows": "sc query Redis && redis-cli --version"
        }
      }
    },
